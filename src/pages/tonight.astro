---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Tonight's Sky — ${SITE_TITLE}`} description="Enter your location to find light pollution levels and what is visible tonight." />
    <style>
      .tonight-wrap { padding: 4rem 0 6rem; }
      .tonight-intro { margin-bottom: 3rem; }
      .tonight-intro h1 { font-family: var(--font-display); font-size: clamp(2rem,4vw,3rem); font-weight: 300; color: var(--star-white); margin: 1rem 0 1rem; }
      .tonight-intro p { color: var(--text-secondary); font-size: 0.95rem; line-height: 1.8; }
      .location-form { display: flex; gap: 0.75rem; margin-bottom: 2.5rem; flex-wrap: wrap; align-items: flex-end; }
      .location-input-wrap { flex: 1; min-width: 220px; }
      .location-label { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); display: block; margin-bottom: 0.5rem; }
      .location-input { width: 100%; background: rgba(13,20,36,0.7); border: 1px solid var(--border-subtle); color: var(--text-primary); font-family: var(--font-mono); font-size: 0.82rem; padding: 0.65em 1em; border-radius: 2px; outline: none; transition: border-color 0.2s; }
      .location-input:focus { border-color: var(--accent-cyan); }
      .location-input::placeholder { color: var(--text-muted); }
      .btn { background: transparent; border: 1px solid var(--accent-gold); color: var(--accent-gold); font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.7em 1.4em; border-radius: 2px; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
      .btn:hover { background: rgba(200,169,110,0.1); color: var(--star-white); }
      .btn-secondary { border-color: var(--border-subtle); color: var(--text-muted); }
      .btn-secondary:hover { border-color: var(--accent-cyan); color: var(--accent-cyan); background: transparent; }
      .loading { display: none; font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent-cyan); letter-spacing: 0.1em; padding: 1rem 0; }
      .loading.visible { display: block; }
      .error-msg { display: none; font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent-rose); padding: 0.75rem 1rem; border: 1px solid rgba(224,112,133,0.2); border-radius: 2px; margin-bottom: 1.5rem; }
      .error-msg.visible { display: block; }
      #results { display: none; }
      #results.visible { display: block; }
      .result-location { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border-subtle); }
      .result-city { font-family: var(--font-display); font-size: 1.8rem; font-weight: 300; color: var(--star-white); margin-bottom: 0.3rem; }
      .result-coords { font-family: var(--font-mono); font-size: 0.62rem; color: var(--text-muted); letter-spacing: 0.08em; }
      .stats-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(180px,1fr)); gap: 1px; background: var(--border-subtle); border: 1px solid var(--border-subtle); margin-bottom: 3rem; }
      .stat-card { background: var(--space-black); padding: 1.4rem 1.5rem; }
      .stat-label { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.5rem; display: block; }
      .stat-value { font-family: var(--font-display); font-size: 1.6rem; font-weight: 300; line-height: 1.1; }
      .stat-sub { font-size: 0.78rem; color: var(--text-secondary); margin-top: 0.3rem; }
      .b1,.b2{color:#4fc3f7} .b3,.b4{color:#a5d6a7} .b5{color:#fff176} .b6,.b7{color:#ffab91} .b8,.b9{color:#e57373}
      .section-header { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 1.5rem; padding-bottom: 0.6rem; border-bottom: 1px solid var(--border-subtle); }
      .objects-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(260px,1fr)); gap: 1.5px; background: var(--border-subtle); border: 1px solid var(--border-subtle); margin-bottom: 3rem; }
      .object-card { background: var(--space-black); display: flex; flex-direction: column; overflow: hidden; transition: background 0.2s; }
      .object-card:hover { background: var(--space-navy); }
      .object-img { width: 100%; height: 140px; object-fit: cover; filter: brightness(0.8) saturate(0.85); display: block; }
      .object-img-fallback { width: 100%; height: 140px; background: linear-gradient(135deg,var(--space-navy),var(--nebula-blue)); display: flex; align-items: center; justify-content: center; font-size: 2.5rem; }
      .object-body { padding: 1.2rem; flex: 1; display: flex; flex-direction: column; gap: 0.3rem; }
      .object-name { font-family: var(--font-display); font-size: 1.1rem; font-weight: 300; color: var(--star-white); }
      .object-type { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent-violet); }
      .object-desc { font-size: 0.8rem; color: var(--text-secondary); line-height: 1.65; flex: 1; }
      .object-footer { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.6rem; }
      .object-vis { display: inline-flex; align-items: center; font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.2em 0.6em; border-radius: 2px; }
      .vis-naked { background: rgba(79,195,247,0.1); color: var(--accent-cyan); border: 1px solid rgba(79,195,247,0.2); }
      .vis-bino { background: rgba(200,169,110,0.1); color: var(--accent-gold); border: 1px solid rgba(200,169,110,0.2); }
      .vis-scope { background: rgba(156,111,228,0.1); color: var(--accent-violet); border: 1px solid rgba(156,111,228,0.2); }
      .object-time { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-muted); }
      .weather-bar { display: flex; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 2rem; padding: 1.2rem 1.5rem; background: rgba(13,20,36,0.5); border: 1px solid var(--border-subtle); }
      .weather-item { display: flex; flex-direction: column; gap: 0.2rem; }
      .weather-label { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); }
      .weather-value { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-primary); }
      @media(max-width:700px){.location-form{flex-direction:column}.objects-grid{grid-template-columns:1fr}}
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="wide-wrapper tonight-wrap">
        <div class="tonight-intro">
          <span class="hero-eyebrow">✦ your sky tonight ✦</span>
          <h1>What can you see tonight?</h1>
          <p>Enter your city or use your location. The page fetches real light pollution data, live weather, and shows everything currently visible from your sky.</p>
        </div>
        <div class="location-form">
          <div class="location-input-wrap">
            <label class="location-label" for="city-input">City or place name</label>
            <input class="location-input" type="text" id="city-input" placeholder="e.g. Indore, Antarctica, Atacama..." autocomplete="off" />
          </div>
          <button class="btn" id="search-btn">Search</button>
          <button class="btn btn-secondary" id="locate-btn">Use my location</button>
        </div>
        <div class="loading" id="loading">Scanning the sky...</div>
        <div class="error-msg" id="error-msg"></div>
        <div id="results">
          <div class="result-location">
            <div class="result-city" id="result-city"></div>
            <div class="result-coords" id="result-coords"></div>
          </div>
          <p class="section-header">Conditions Tonight</p>
          <div class="weather-bar" id="weather-bar"></div>
          <p class="section-header">Light Pollution</p>
          <div class="stats-grid" id="stats-grid"></div>
          <p class="section-header" id="naked-header" style="margin-top:2.5rem;">Visible to the Naked Eye</p>
          <div class="objects-grid" id="naked-grid"></div>
          <p class="section-header" id="scope-header">Visible with Binoculars and Telescope</p>
          <div class="objects-grid" id="scope-grid"></div>
        </div>
      </div>
    </main>
    <Footer />

    <script>
      // ── Complete sky object database ────────────────────────────────────
      // minBortle: maximum Bortle class where this is visible (9 = always)
      // Images: real NASA/ESO/Hubble public domain URLs
      const DB = [
        // Always visible (planets, Moon, bright stars)
        { name:'The Moon', type:'Natural Satellite', vis:'naked', minBortle:9,
          desc:'Even to the naked eye, maria and highland regions are distinct. Binoculars reveal hundreds of craters. Changes phase over 29.5 days.',
          img:'https://images.unsplash.com/photo-1532693322450-2cb5c511067d?w=600&fit=crop',
          rise:18, set:6 },
        { name:'Venus', type:'Planet', vis:'naked', minBortle:9,
          desc:'The brightest natural object after the Sun and Moon. Never strays far from the Sun — look near the horizon at dawn or dusk.',
          img:'https://images.unsplash.com/photo-1614313913007-2b4ae8ce32d6?w=600&fit=crop',
          rise:5, set:9 },
        { name:'Jupiter', type:'Planet', vis:'naked', minBortle:9,
          desc:'Often the brightest star-like object in the sky. Four Galilean moons visible in binoculars. Cloud bands visible in a small telescope.',
          img:'https://images.unsplash.com/photo-1614314169000-4f44e7f7f7c6?w=600&fit=crop',
          rise:20, set:4 },
        { name:'Saturn', type:'Planet', vis:'naked', minBortle:9,
          desc:'Visible as a steady golden star. The rings are unmistakable even in a small telescope — never fails to astonish first-time viewers.',
          img:'https://images.unsplash.com/photo-1614732484003-ef9881555dc3?w=600&fit=crop',
          rise:21, set:5 },
        { name:'Mars', type:'Planet', vis:'naked', minBortle:9,
          desc:'Unmistakable reddish-orange colour. Brightness varies dramatically — at opposition it rivals Jupiter.',
          img:'https://images.unsplash.com/photo-1614728894747-a83421e2b9c9?w=600&fit=crop',
          rise:22, set:6 },
        { name:'Mercury', type:'Planet', vis:'naked', minBortle:8,
          desc:'The innermost planet, always close to the Sun. Visible low on the horizon for short windows after sunset or before sunrise.',
          img:'https://images.unsplash.com/photo-1502134249126-9f3755a50d78?w=600&fit=crop',
          rise:6, set:8 },
        { name:'Sirius', type:'Star (brightest)', vis:'naked', minBortle:8,
          desc:'The brightest star in the night sky, in Canis Major. Blue-white and brilliant. Its slight twinkling and colour make it one of the most striking naked-eye stars.',
          img:'https://images.unsplash.com/photo-1419242902214-272b3f66ee7a?w=600&fit=crop',
          rise:19, set:3 },
        { name:'Orion Constellation', type:'Constellation', vis:'naked', minBortle:7,
          desc:'The hunter — one of the most recognisable star patterns. Three belt stars unmistakable. Betelgeuse (red supergiant) at one shoulder, Rigel (blue supergiant) at the foot.',
          img:'https://images.unsplash.com/photo-1444703686981-a3abbc4d4fe3?w=600&fit=crop',
          rise:20, set:4 },
        { name:'Pleiades (M45)', type:'Open Cluster', vis:'naked', minBortle:6,
          desc:'Six or more stars visible naked eye in good conditions. A beautiful binocular target revealing dozens of young blue stars in a tight group.',
          img:'https://images.unsplash.com/photo-1559825481-12a05cc00344?w=600&fit=crop',
          rise:19, set:2 },
        { name:'Milky Way Core', type:'Galaxy', vis:'naked', minBortle:3,
          desc:'Our galaxy\'s central band. In Bortle 1-3 skies it stretches horizon to horizon and is bright enough to cast faint shadows. Completely invisible from any city.',
          img:'https://images.unsplash.com/photo-1502134249126-9f3755a50d78?w=600&fit=crop',
          rise:22, set:4 },
        { name:'Zodiacal Light', type:'Atmospheric Phenomenon', vis:'naked', minBortle:2,
          desc:'A faint pyramid of light extending from the horizon along the ecliptic. Only visible from very dark sites. Caused by sunlight scattering off interplanetary dust.',
          img:'https://images.unsplash.com/photo-1446776858070-70c3d5ed6758?w=600&fit=crop',
          rise:19, set:22 },
        // Binocular objects
        { name:'Andromeda Galaxy (M31)', type:'Galaxy', vis:'bino', minBortle:5,
          desc:'Nearest major galaxy, 2.5 million light years away. Binoculars show its full oval extent, wider than six full Moons.',
          img:'https://images.unsplash.com/photo-1543722530-d2c3201371e7?w=600&fit=crop',
          rise:20, set:3 },
        { name:'Orion Nebula (M42)', type:'Emission Nebula', vis:'bino', minBortle:6,
          desc:'A stellar nursery 1,344 light years away. Visible naked eye as a fuzzy star in Orion\'s sword. Binoculars reveal the glowing gas cloud and the Trapezium cluster.',
          img:'https://images.unsplash.com/photo-1462331940025-496dfbfc7564?w=600&fit=crop',
          rise:20, set:4 },
        { name:'Beehive Cluster (M44)', type:'Open Cluster', vis:'bino', minBortle:6,
          desc:'A nearby open cluster in Cancer visible to the naked eye in dark skies. Binoculars resolve it into dozens of stars spread across a region wider than the Moon.',
          img:'https://images.unsplash.com/photo-1419242902214-272b3f66ee7a?w=600&fit=crop',
          rise:19, set:3 },
        { name:'Double Cluster (NGC 869/884)', type:'Open Cluster', vis:'bino', minBortle:5,
          desc:'Two rich open clusters side by side in Perseus. Hundreds of young stars in a single binocular field of view — one of the finest sights in the northern sky.',
          img:'https://images.unsplash.com/photo-1559825481-12a05cc00344?w=600&fit=crop',
          rise:19, set:5 },
        { name:'Omega Centauri (NGC 5139)', type:'Globular Cluster', vis:'bino', minBortle:5,
          desc:'The largest globular cluster in the Milky Way — 10 million stars in a ball 150 light years across. Best from the Southern Hemisphere. A naked eye object from dark sites.',
          img:'https://images.unsplash.com/photo-1446776858070-70c3d5ed6758?w=600&fit=crop',
          rise:22, set:4 },
        { name:'47 Tucanae (NGC 104)', type:'Globular Cluster', vis:'bino', minBortle:4,
          desc:'The second brightest globular cluster, appearing next to the Small Magellanic Cloud. One million stars packed into a sphere 120 light years across.',
          img:'https://images.unsplash.com/photo-1419242902214-272b3f66ee7a?w=600&fit=crop',
          rise:21, set:5 },
        // Telescope objects
        { name:'Ring Nebula (M57)', type:'Planetary Nebula', vis:'scope', minBortle:7,
          desc:'A dying star\'s expelled shell in Lyra. Even a small telescope reveals the distinctive smoke-ring shape around the central white dwarf.',
          img:'https://images.unsplash.com/photo-1446941611757-91d2c3bd3d45?w=600&fit=crop',
          rise:21, set:5 },
        { name:'Whirlpool Galaxy (M51)', type:'Spiral Galaxy', vis:'scope', minBortle:4,
          desc:'A face-on spiral galaxy interacting with a companion. Long exposures reveal spiral arms. One of the most photographed deep sky objects.',
          img:'https://images.unsplash.com/photo-1454789548928-9efd52dc4031?w=600&fit=crop',
          rise:21, set:4 },
        { name:'Crab Nebula (M1)', type:'Supernova Remnant', vis:'scope', minBortle:5,
          desc:'Remnant of a supernova seen in 1054 AD. Still expanding at 1,500 km/s. A telescope shows tangled glowing filaments powered by a central pulsar.',
          img:'https://images.unsplash.com/photo-1462331940025-496dfbfc7564?w=600&fit=crop',
          rise:20, set:3 },
        { name:'Sombrero Galaxy (M104)', type:'Galaxy', vis:'scope', minBortle:4,
          desc:'An edge-on spiral with a bright nucleus and a prominent dark dust lane. One of the most distinctive galaxy shapes in the Messier catalogue.',
          img:'https://images.unsplash.com/photo-1543722530-d2c3201371e7?w=600&fit=crop',
          rise:21, set:4 },
        { name:'Lagoon Nebula (M8)', type:'Emission Nebula', vis:'scope', minBortle:5,
          desc:'A bright emission nebula and open cluster in Sagittarius. Visible to the naked eye from dark sites, stunning in a telescope with glowing gas clouds.',
          img:'https://images.unsplash.com/photo-1446941611757-91d2c3bd3d45?w=600&fit=crop',
          rise:22, set:4 },
        { name:'Triangulum Galaxy (M33)', type:'Galaxy', vis:'scope', minBortle:3,
          desc:'The third largest galaxy in the Local Group at 2.7 million light years. Requires a very dark sky to see well — it covers an area larger than the full Moon.',
          img:'https://images.unsplash.com/photo-1454789548928-9efd52dc4031?w=600&fit=crop',
          rise:20, set:3 },
        { name:'Eta Carinae Nebula', type:'Emission Nebula', vis:'scope', minBortle:4,
          desc:'One of the largest and most luminous nebulae visible, in the Southern Hemisphere. Contains the unstable hypergiant star Eta Carinae, which may explode as a supernova.',
          img:'https://images.unsplash.com/photo-1462331940025-496dfbfc7564?w=600&fit=crop',
          rise:21, set:5 },
      ];

      // Bortle estimation handled by getRealBortle() above

      function getBortleInfo(b: number) {
        return [
          null,
          { label:'Exceptional Dark', sky:'Zodiacal light, gegenschein visible. Milky Way casts shadows.', limiting:'8.0 mag' },
          { label:'Truly Dark', sky:'M33 visible directly. Milky Way shows complex structure.', limiting:'7.5 mag' },
          { label:'Rural', sky:'Some horizon glow. Milky Way still shows fine detail.', limiting:'7.1 mag' },
          { label:'Rural/Suburban', sky:'Light domes on horizon. Milky Way impressive but washed overhead.', limiting:'6.8 mag' },
          { label:'Suburban', sky:'Milky Way visible but lacks contrast. Many Messier objects in binoculars.', limiting:'6.3 mag' },
          { label:'Bright Suburban', sky:'Milky Way near zenith only. Most Messier objects in telescope.', limiting:'5.9 mag' },
          { label:'Suburban/Urban', sky:'Milky Way invisible. Only bright clusters and doubles worthwhile.', limiting:'5.6 mag' },
          { label:'City', sky:'Only bright stars visible. Planets and Moon dominate.', limiting:'5.0 mag' },
          { label:'Inner City', sky:'About 20 stars visible. Sky is grey-orange, not black.', limiting:'4.5 mag' },
        ][Math.min(9, Math.max(1, b))];
      }

      function fmtTime(hour: number, tzOffset: number): string {
        const local = ((hour + tzOffset) % 24 + 24) % 24;
        const ampm = local >= 12 ? 'PM' : 'AM';
        const h = local % 12 || 12;
        return `${h}:00 ${ampm}`;
      }

      function renderCard(obj: typeof DB[0], tzOffset: number): string {
        const visClass = obj.vis==='naked'?'vis-naked':obj.vis==='bino'?'vis-bino':'vis-scope';
        const visLabel = obj.vis==='naked'?'Naked Eye':obj.vis==='bino'?'Binoculars':'Telescope';
        const window = `${fmtTime(obj.rise,tzOffset)} – ${fmtTime(obj.set,tzOffset)}`;
        return `
          <div class="object-card">
            <img class="object-img" src="${obj.img}" alt="${obj.name}" loading="lazy"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="object-img-fallback" style="display:none">✦</div>
            <div class="object-body">
              <div class="object-name">${obj.name}</div>
              <div class="object-type">${obj.type}</div>
              <div class="object-desc">${obj.desc}</div>
              <div class="object-footer">
                <span class="object-vis ${visClass}">${visLabel}</span>
                <span class="object-time">Visible: ${window}</span>
              </div>
            </div>
          </div>`;
      }

      // ── DOM ──────────────────────────────────────────────────────────────
      const cityInput = document.getElementById('city-input') as HTMLInputElement;
      const searchBtn = document.getElementById('search-btn')!;
      const locateBtn = document.getElementById('locate-btn')!;
      const loadingEl = document.getElementById('loading')!;
      const errorEl   = document.getElementById('error-msg')!;
      const resultsEl = document.getElementById('results')!;

      function showLoading(msg='Scanning the sky...') {
        loadingEl.textContent=msg; loadingEl.classList.add('visible');
        errorEl.classList.remove('visible'); resultsEl.classList.remove('visible');
      }
      function hideLoading() { loadingEl.classList.remove('visible'); }
      function showError(msg: string) { hideLoading(); errorEl.textContent=msg; errorEl.classList.add('visible'); }

      async function geocode(city: string) {
        const r = await fetch(`https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(city)}&count=1&language=en&format=json`);
        const d = await r.json();
        if (!d.results?.length) return null;
        const x = d.results[0];
        return { lat:x.latitude, lon:x.longitude, name:x.name, country:x.country??'', admin:x.admin1??'', population:x.population??0 };
      }

      // Bortle calculated directly from geocode population field

      function popToBortle(lat: number, lon: number, pop: number): number {
        // Known dark site bounding boxes override population data
        const absLat = Math.abs(lat);
        if (absLat > 66) return 1;                                              // polar
        if (lat>-26&&lat<-18&&lon>-72&&lon<-65) return 1;                      // Atacama
        if (lat>-35&&lat<-20&&lon>140&&lon<150&&pop<5000) return 2;            // Australian outback
        if (lat>18&&lat<32&&lon>0&&lon<35&&pop<10000) return 2;                // Sahara
        if (lat>42&&lat<50&&lon>90&&lon<118&&pop<20000) return 2;              // Mongolian steppe
        if (lat>35&&lat<42&&lon>-115&&lon<-105&&pop<10000) return 2;           // US high desert
        if (absLat>55&&pop<5000) return 2;                                      // remote high lat
        if (absLat>45&&pop<20000) return 3;                                     // remote mid lat
        // Population-based for everything else
        if (pop === 0) return 3;
        if (pop < 1000) return 3;
        if (pop < 5000) return 4;
        if (pop < 20000) return 5;
        if (pop < 100000) return 6;
        if (pop < 500000) return 7;
        if (pop < 2000000) return 8;
        return 9;
      }



      async function renderResults(lat: number, lon: number, cityName: string, country: string, population: number = 0) {
        try {
          showLoading('Fetching weather and light pollution data...');
          const [weather] = await Promise.all([
            fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&daily=precipitation_probability_max,cloudcover_mean&current_weather=true&forecast_days=1&timezone=auto`).then(r => r.json()),
          ]);
          const bortle = popToBortle(lat, lon, population);
          const info = getBortleInfo(bortle)!;
          const cloud = weather.daily?.cloudcover_mean?.[0] ?? 50;
          const temp = weather.current_weather?.temperature ?? 'N/A';
          const wind = weather.current_weather?.windspeed ?? 'N/A';
          const precip = weather.daily?.precipitation_probability_max?.[0] ?? 'N/A';
          const skyQ = cloud<20?'Clear':cloud<50?'Partly Cloudy':cloud<80?'Mostly Cloudy':'Overcast';
          const skyC = cloud<20?'var(--accent-cyan)':cloud<50?'var(--accent-gold)':'var(--accent-rose)';
          const tzOffset = Math.round(lon / 15);

          document.getElementById('result-city')!.textContent = `${cityName}${country?', '+country:''}`;
          document.getElementById('result-coords')!.textContent = `${lat.toFixed(4)}°, ${lon.toFixed(4)}° · UTC${tzOffset>=0?'+':''}${tzOffset}`;

          document.getElementById('weather-bar')!.innerHTML = `
            <div class="weather-item"><span class="weather-label">Sky Tonight</span><span class="weather-value" style="color:${skyC}">${skyQ}</span></div>
            <div class="weather-item"><span class="weather-label">Cloud Cover</span><span class="weather-value">${Math.round(cloud)}%</span></div>
            <div class="weather-item"><span class="weather-label">Temperature</span><span class="weather-value">${temp}°C</span></div>
            <div class="weather-item"><span class="weather-label">Wind</span><span class="weather-value">${wind} km/h</span></div>
            <div class="weather-item"><span class="weather-label">Rain Chance</span><span class="weather-value">${precip}%</span></div>
            <div class="weather-item"><span class="weather-label">Best Viewing</span><span class="weather-value" style="color:var(--accent-gold)">${cloud<30?'Good tonight':cloud<60?'Partly usable':'Poor conditions'}</span></div>`;

          document.getElementById('stats-grid')!.innerHTML = `
            <div class="stat-card"><span class="stat-label">Bortle Class</span><div class="stat-value b${bortle}">${bortle} / 9</div><div class="stat-sub">${info.label}</div></div>
            <div class="stat-card"><span class="stat-label">Sky Description</span><div style="font-size:0.85rem;color:var(--text-secondary);margin-top:0.4rem;line-height:1.6">${info.sky}</div></div>
            <div class="stat-card"><span class="stat-label">Limiting Magnitude</span><div class="stat-value" style="color:var(--accent-cyan)">${info.limiting}</div><div class="stat-sub">Faintest naked eye star</div></div>
            <div class="stat-card"><span class="stat-label">Milky Way</span><div class="stat-value" style="font-size:1.1rem;color:var(--text-primary);margin-top:0.3rem">${bortle<=2?'Casts shadows':bortle<=3?'Spectacular':bortle<=5?'Visible':bortle<=6?'Faint':'Invisible'}</div></div>`;

          const visible = DB.filter(o => bortle <= o.minBortle);
          const naked = visible.filter(o => o.vis==='naked');
          const rest  = visible.filter(o => o.vis!=='naked');

          document.getElementById('naked-header')!.textContent = `Visible to the Naked Eye (${naked.length} objects)`;
          document.getElementById('naked-grid')!.innerHTML = naked.map(o=>renderCard(o,tzOffset)).join('');
          document.getElementById('scope-header')!.textContent = `Binoculars and Telescope (${rest.length} objects)`;
          document.getElementById('scope-grid')!.innerHTML = rest.map(o=>renderCard(o,tzOffset)).join('');

          hideLoading(); resultsEl.classList.add('visible');
        } catch(e) {
          console.error('Sky data error:', e);
          showError('Could not fetch sky data. Check console for details.');
        }
      }

      searchBtn.addEventListener('click', async () => {
        const city = cityInput.value.trim();
        if (!city) return;
        showLoading('Looking up location...');
        const geo = await geocode(city);
        if (!geo) { showError(`Could not find "${city}". Try a different spelling.`); return; }
        await renderResults(geo.lat, geo.lon, geo.name, geo.country, geo.population);
      });

      cityInput.addEventListener('keydown', e => { if(e.key==='Enter') searchBtn.click(); });

      locateBtn.addEventListener('click', () => {
        if (!navigator.geolocation) { showError('Geolocation not supported.'); return; }
        showLoading('Getting your location...');
        navigator.geolocation.getCurrentPosition(
          async p => await renderResults(p.coords.latitude, p.coords.longitude, 'Your Location', ''),
          () => showError('Location access denied. Please type your city.')
        );
      });
    </script>
  </body>
</html>