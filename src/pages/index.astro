---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getReadingTime } from '../utils/readingTime';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Feature 5: Featured hero — first post marked featured, or fall back to latest
const featuredPost = allPosts.find((p) => p.data.featured) ?? allPosts[0];

// Feature 1: Recent observations — 3 most recent (excluding the featured)
const recentPosts = allPosts.filter((p) => p.id !== featuredPost?.id).slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* ── Hero section ─────────────────────────────────────── */
			.hero-label {
				display: inline-block;
				font-size: 0.65rem;
				font-weight: 700;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--accent);
				border: 1px solid var(--accent);
				border-radius: 2px;
				padding: 2px 8px;
				margin-bottom: 0.9rem;
			}
			.hero-post {
				border-top: 2px solid rgb(var(--black));
				padding-top: 2rem;
				margin-bottom: 3.5rem;
			}
			.hero-post a {
				text-decoration: none;
				color: inherit;
			}
			.hero-post a:hover .hero-title {
				color: var(--accent);
			}
			.hero-title {
				font-size: clamp(1.6rem, 4vw, 2.6rem);
				line-height: 1.15;
				margin: 0 0 0.6rem 0;
				transition: color 0.15s ease;
			}
			.hero-meta {
				display: flex;
				align-items: center;
				gap: 1rem;
				flex-wrap: wrap;
				margin-bottom: 0.8rem;
			}
			.hero-date {
				font-size: 0.8rem;
				color: rgb(var(--gray));
			}
			.reading-time {
				font-size: 0.75rem;
				color: rgb(var(--gray));
				padding-left: 0.8rem;
				border-left: 1px solid rgb(var(--gray-light));
			}
			.hero-description {
				font-size: 1.05rem;
				color: rgb(var(--gray-dark));
				line-height: 1.6;
				max-width: 58ch;
				margin: 0 0 1rem 0;
			}
			.hero-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
			}

			/* ── Tags ─────────────────────────────────────────────── */
			.tag {
				font-size: 0.68rem;
				font-weight: 500;
				letter-spacing: 0.04em;
				color: rgb(var(--gray));
				background: rgb(var(--gray-light));
				border-radius: 2px;
				padding: 2px 7px;
				text-decoration: none;
				transition: background 0.15s, color 0.15s;
			}
			.tag:hover {
				background: var(--accent);
				color: white;
			}
			.tag::before {
				content: '#';
				opacity: 0.5;
			}

			/* ── Recent observations section ─────────────────────── */
			.section-header {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				border-top: 1px solid rgb(var(--gray-light));
				padding-top: 1.6rem;
				margin-bottom: 1.4rem;
			}
			.section-title {
				font-size: 0.7rem;
				font-weight: 700;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin: 0;
			}
			.view-all {
				font-size: 0.75rem;
				color: var(--accent);
				text-decoration: none;
				letter-spacing: 0.03em;
			}
			.view-all:hover {
				text-decoration: underline;
			}
			.recent-list {
				list-style: none;
				padding: 0;
				margin: 0 0 3rem 0;
				display: flex;
				flex-direction: column;
				gap: 0;
			}
			.recent-item {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.recent-item a {
				display: grid;
				grid-template-columns: 1fr auto;
				gap: 0.5rem 1.5rem;
				align-items: start;
				padding: 1.1rem 0;
				text-decoration: none;
				color: inherit;
				transition: none;
			}
			.recent-item a:hover .recent-title {
				color: var(--accent);
			}
			.recent-item a:hover .recent-teaser {
				color: rgb(var(--gray-dark));
			}
			.recent-content {
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}
			.recent-title {
				font-size: 1rem;
				font-weight: 700;
				line-height: 1.3;
				margin: 0;
				color: rgb(var(--black));
				transition: color 0.15s ease;
			}
			.recent-teaser {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				line-height: 1.5;
				margin: 0;
				transition: color 0.15s ease;
			}
			.recent-tags {
				display: flex;
				gap: 0.3rem;
				flex-wrap: wrap;
				margin-top: 0.3rem;
			}
			.recent-aside {
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				gap: 0.2rem;
				white-space: nowrap;
				padding-top: 0.1rem;
			}
			.recent-date {
				font-size: 0.75rem;
				color: rgb(var(--gray));
			}
			.recent-read {
				font-size: 0.7rem;
				color: rgb(var(--gray));
				opacity: 0.75;
			}

			/* ── Search bar ───────────────────────────────────────── */
			.search-wrap {
				border-top: 1px solid rgb(var(--gray-light));
				padding-top: 1.6rem;
				margin-bottom: 2rem;
			}
			.search-inner {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				max-width: 400px;
			}
			.search-icon {
				color: rgb(var(--gray));
				flex-shrink: 0;
				width: 16px;
				height: 16px;
			}
			.search-input {
				flex: 1;
				border: none;
				border-bottom: 1px solid rgb(var(--gray-light));
				background: transparent;
				font-size: 0.85rem;
				font-family: inherit;
				color: rgb(var(--gray-dark));
				padding: 4px 2px;
				outline: none;
				transition: border-color 0.15s;
			}
			.search-input::placeholder {
				color: rgb(var(--gray));
				opacity: 0.7;
			}
			.search-input:focus {
				border-bottom-color: var(--accent);
			}
			.search-hint {
				font-size: 0.68rem;
				color: rgb(var(--gray));
				margin-top: 0.4rem;
				margin-left: 1.5rem;
				opacity: 0;
				transition: opacity 0.15s;
			}
			.search-wrap:focus-within .search-hint {
				opacity: 1;
			}

			/* hide posts that don't match search */
			.recent-item[data-hidden="true"] {
				display: none;
			}
			.no-results {
				display: none;
				font-size: 0.85rem;
				color: rgb(var(--gray));
				padding: 1rem 0;
			}
			.no-results.visible {
				display: block;
			}

			@media (max-width: 600px) {
				.recent-item a {
					grid-template-columns: 1fr;
				}
				.recent-aside {
					flex-direction: row;
					align-items: center;
					gap: 0.6rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>

			<!-- ── Feature 5: Featured Hero Article ──────────────── -->
			{featuredPost && (
				<div class="hero-post">
					<span class="hero-label">Latest dispatch from the void</span>
					<a href={`/blog/${featuredPost.id}/`}>
						<h1 class="hero-title">{featuredPost.data.title}</h1>
					</a>
					<div class="hero-meta">
						<span class="hero-date">
							<FormattedDate date={featuredPost.data.pubDate} />
						</span>
						<span class="reading-time">
							{getReadingTime(featuredPost.body ?? '')}
						</span>
					</div>
					<p class="hero-description">{featuredPost.data.description}</p>
					{featuredPost.data.tags.length > 0 && (
						<div class="hero-tags">
							{featuredPost.data.tags.map((tag) => (
								<a class="tag" href={`/blog?tag=${tag}`}>{tag}</a>
							))}
						</div>
					)}
				</div>
			)}

			<!-- ── Feature 1 + 3: Recent Observations + Search ───── -->
			<div class="section-header">
				<h2 class="section-title">Recent Observations</h2>
				<a class="view-all" href="/blog">View all posts →</a>
			</div>

			<!-- Feature 3: Minimal search bar -->
			<div class="search-wrap">
				<div class="search-inner">
					<svg class="search-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
						<circle cx="6.5" cy="6.5" r="4.5"/>
						<path d="m10 10 3.5 3.5" stroke-linecap="round"/>
					</svg>
					<input
						id="post-search"
						class="search-input"
						type="search"
						placeholder="Search posts…"
						aria-label="Search posts"
						autocomplete="off"
					/>
				</div>
				<p class="search-hint">Type to filter posts by title or tag</p>
			</div>

			<ul class="recent-list" id="recent-list">
				{recentPosts.map((post) => (
					<li
						class="recent-item"
						data-title={post.data.title.toLowerCase()}
						data-tags={post.data.tags.join(' ').toLowerCase()}
					>
						<a href={`/blog/${post.id}/`}>
							<div class="recent-content">
								<!-- Feature 1: Title + teaser -->
								<h3 class="recent-title">{post.data.title}</h3>
								<p class="recent-teaser">{post.data.description}</p>
								<!-- Feature 2: Topic tags -->
								{post.data.tags.length > 0 && (
									<div class="recent-tags">
										{post.data.tags.map((tag) => (
											<span class="tag">{tag}</span>
										))}
									</div>
								)}
							</div>
							<div class="recent-aside">
								<!-- Feature 1: Date -->
								<span class="recent-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
								<!-- Feature 4: Reading time -->
								<span class="recent-read">
									{getReadingTime(post.body ?? '')}
								</span>
							</div>
						</a>
					</li>
				))}
			</ul>
			<p class="no-results" id="no-results">No posts match your search.</p>

		</main>
		<Footer />

		<!-- Feature 3: Static search script -->
		<script>
			const input = document.getElementById('post-search') as HTMLInputElement;
			const items = document.querySelectorAll<HTMLElement>('.recent-item');
			const noResults = document.getElementById('no-results')!;

			input?.addEventListener('input', () => {
				const query = input.value.trim().toLowerCase();
				let visible = 0;
				items.forEach((item) => {
					const title = item.dataset.title ?? '';
					const tags = item.dataset.tags ?? '';
					const matches = !query || title.includes(query) || tags.includes(query);
					item.dataset.hidden = matches ? 'false' : 'true';
					if (matches) visible++;
				});
				noResults.classList.toggle('visible', visible === 0 && query.length > 0);
			});
		</script>
	</body>
</html>