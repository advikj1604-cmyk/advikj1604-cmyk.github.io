---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date) - new Date(a.data.date))
  .slice(0, 3);
---

<html>
  <head>
    <title>Advik’s Blog</title>
  </head>

  <body style="font-family: system-ui; max-width: 700px; margin: auto; padding: 40px;">
    
    <h1>🌌 Advik’s Blog</h1>
    <p>Physics • Astronomy • Machine Learning</p>

    <hr />

    <h2>Latest Posts</h2>

    <ul>
      {posts.map(post => (
        <li>
          <a href={`/blog/${post.slug}/`}>
            {post.data.title}
          </a>
          <small> — {post.data.date}</small>
        </li>
      ))}
    </ul>

    <hr />

    <a href="/blog">View all posts →</a>

  </body>
</html>