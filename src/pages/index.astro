---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 4);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero wide-wrapper">
        <span class="hero-eyebrow fade-up">✦ &nbsp; dispatches from the void &nbsp; ✦</span>
        <h1 class="hero-title fade-up fade-up-delay-1">
          Notes from<br /><em>between the stars</em>
        </h1>
        <p class="hero-subtitle fade-up fade-up-delay-2">
          A journal of astronomy, cosmology, and the quiet wonder of looking up at the dark.
        </p>
        <div class="hero-divider fade-up fade-up-delay-3"></div>
      </section>

      <section class="posts-section wide-wrapper">
        <p class="section-label">Recent Observations</p>
        <div class="posts-grid">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}/`} class="post-card">
              <span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
              <h2 class="post-card-title">{post.data.title}</h2>
              {post.data.description && (
                <p class="post-card-desc">{post.data.description}</p>
              )}
              <span class="post-card-arrow">Read more →</span>
            </a>
          ))}
        </div>
        <div style="text-align:center; margin-top:2.5rem;">
          <a href="/blog" style="font-family:var(--font-mono); font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--accent-gold); border:1px solid rgba(200,169,110,0.3); padding:0.6em 1.5em; border-radius:2px; text-decoration:none; transition:background 0.2s;">
            View all posts →
          </a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>