---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Contact — ${SITE_TITLE}`} description="Get in touch with Advik Jain." />
    <style>
      .contact-wrap {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        padding: 5rem 0 6rem;
        align-items: start;
      }
      .contact-intro h1 {
        font-family: var(--font-display);
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 300;
        color: var(--star-white);
        margin: 1rem 0 1.5rem;
      }
      .contact-intro p {
        color: var(--text-secondary);
        font-size: 0.95rem;
        line-height: 1.8;
        margin-bottom: 1.2rem;
      }
      .contact-detail {
        margin-top: 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
      }
      .contact-detail-item {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .detail-label {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-muted);
      }
      .detail-value {
        font-size: 0.9rem;
        color: var(--text-secondary);
      }
      /* Form */
      .contact-form {
        background: rgba(13, 20, 36, 0.5);
        border: 1px solid var(--border-subtle);
        padding: 2.5rem;
      }
      .form-group {
        margin-bottom: 1.5rem;
      }
      .form-label {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 0.5rem;
      }
      .form-input,
      .form-textarea,
      .form-select {
        width: 100%;
        background: rgba(4, 5, 10, 0.6);
        border: 1px solid var(--border-subtle);
        color: var(--text-primary);
        font-family: var(--font-body);
        font-size: 0.9rem;
        padding: 0.7em 1em;
        border-radius: 2px;
        outline: none;
        transition: border-color 0.2s;
        -webkit-appearance: none;
      }
      .form-input:focus,
      .form-textarea:focus,
      .form-select:focus {
        border-color: var(--accent-cyan);
      }
      .form-input::placeholder,
      .form-textarea::placeholder {
        color: var(--text-muted);
      }
      .form-textarea {
        resize: vertical;
        min-height: 140px;
        line-height: 1.7;
      }
      .form-select option {
        background: var(--space-navy);
      }
      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }
      .submit-btn {
        width: 100%;
        background: transparent;
        border: 1px solid var(--accent-gold);
        color: var(--accent-gold);
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        padding: 0.85em 2em;
        border-radius: 2px;
        cursor: pointer;
        transition: background 0.2s, color 0.2s;
        margin-top: 0.5rem;
      }
      .submit-btn:hover {
        background: rgba(200, 169, 110, 0.1);
        color: var(--star-white);
      }
      .success-msg {
        display: none;
        text-align: center;
        padding: 2rem;
        font-family: var(--font-display);
        font-size: 1.2rem;
        font-style: italic;
        color: var(--accent-gold);
      }
      .form-note {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 1rem;
        font-family: var(--font-mono);
        letter-spacing: 0.03em;
      }
      @media (max-width: 700px) {
        .contact-wrap { grid-template-columns: 1fr; gap: 3rem; }
        .form-row { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="wide-wrapper">
        <div class="contact-wrap">

          <!-- Left: intro -->
          <div class="contact-intro">
            <span class="hero-eyebrow">✦ get in touch ✦</span>
            <h1>Say hello.</h1>
            <p>
              Have a question about something you read? Spotted an error in my science? Want to share what you saw through your own telescope last night? I want to hear it.
            </p>
            <p>
              I read every message, though I may take a few days to reply. No newsletters, no spam, just a real response from a real person who spends too much time looking at the sky.
            </p>
            <div class="contact-detail">
              <div class="contact-detail-item">
                <span class="detail-label">Based in</span>
                <span class="detail-value">India</span>
              </div>
              <div class="contact-detail-item">
                <span class="detail-label">Response time</span>
                <span class="detail-value">Usually within a few days</span>
              </div>
              <div class="contact-detail-item">
                <span class="detail-label">Best for</span>
                <span class="detail-value">Questions, corrections, collaborations, and cosmic wonder</span>
              </div>
            </div>
          </div>

          <!-- Right: form -->
          <div class="contact-form">
            <div id="success-msg" class="success-msg">
              Message received. I will get back to you soon. ✦
            </div>
            <form id="contact-form" action="https://formspree.io/f/mdavgapd" method="POST">
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="name">Name</label>
                  <input class="form-input" type="text" id="name" name="name" placeholder="Your name" required />
                </div>
                <div class="form-group">
                  <label class="form-label" for="email">Email</label>
                  <input class="form-input" type="email" id="email" name="email" placeholder="your@email.com" required />
                </div>
              </div>
              <div class="form-group">
                <label class="form-label" for="subject">Subject</label>
                <select class="form-select" id="subject" name="subject">
                  <option value="general">General message</option>
                  <option value="question">Question about a post</option>
                  <option value="correction">Spotted an error</option>
                  <option value="observation">Sharing an observation</option>
                  <option value="other">Something else</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label" for="message">Message</label>
                <textarea class="form-textarea" id="message" name="message" placeholder="What is on your mind?" required></textarea>
              </div>
              <button class="submit-btn" type="submit">Send message</button>
              <p class="form-note">
                Powered by Formspree. Your email is never shared or sold.
              </p>
            </form>
          </div>

        </div>
      </div>
    </main>
    <Footer />

    <script>
      const form = document.getElementById('contact-form') as HTMLFormElement;
      const successMsg = document.getElementById('success-msg');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.style.display = 'none';
          if (successMsg) successMsg.style.display = 'block';
        }
      });
    </script>
  </body>
</html>