---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))].sort();

function readingTime(body: string) {
  return Math.max(1, Math.ceil(body.trim().split(/\s+/).length / 200));
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description="All posts and observations by Advik Jain." />
    <style>
      .tag-filter { display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:2.5rem; }
      .filter-tag {
        font-family:var(--font-mono);
        font-size:0.62rem;
        letter-spacing:0.1em;
        text-transform:uppercase;
        color:var(--text-muted);
        border:1px solid var(--border-subtle);
        padding:0.25em 0.8em;
        border-radius:2px;
        cursor:pointer;
        transition:all 0.15s;
        background:none;
      }
      .filter-tag:hover, .filter-tag.active {
        color:var(--star-white);
        border-color:var(--accent-violet);
        background:rgba(156,111,228,0.1);
      }
      .post-item {
        display:grid;
        grid-template-columns:80px 1fr auto;
        gap:1.5rem;
        align-items:start;
        padding:1.4rem 0;
        border-bottom:1px solid var(--border-subtle);
        text-decoration:none;
        color:inherit;
        transition:opacity 0.2s;
      }
      .post-item:first-of-type { border-top:1px solid var(--border-subtle); }
      .post-item.hidden { display:none; }
      .post-item:hover .pi-title { color:var(--accent-gold); }
      .pi-date {
        font-family:var(--font-mono);
        font-size:0.62rem;
        letter-spacing:0.08em;
        color:var(--text-muted);
        text-transform:uppercase;
        padding-top:0.2rem;
        line-height:1.6;
      }
      .pi-body { display:flex; flex-direction:column; gap:0.35rem; }
      .pi-title {
        font-family:var(--font-display);
        font-size:1.25rem;
        font-weight:300;
        color:var(--star-white);
        line-height:1.2;
        transition:color 0.2s;
      }
      .pi-desc { font-size:0.83rem; color:var(--text-secondary); line-height:1.6; }
      .pi-tags { display:flex; gap:0.35rem; flex-wrap:wrap; margin-top:0.2rem; }
      .pi-read-time {
        font-family:var(--font-mono);
        font-size:0.6rem;
        color:var(--accent-cyan);
        white-space:nowrap;
        padding-top:0.25rem;
        letter-spacing:0.05em;
      }
      #no-results {
        display:none;
        padding:2rem 0;
        font-family:var(--font-mono);
        font-size:0.78rem;
        color:var(--text-muted);
        letter-spacing:0.05em;
      }
      @media(max-width:700px){
        .post-item{grid-template-columns:60px 1fr;}
        .pi-read-time{display:none;}
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="wide-wrapper" style="padding:4rem 0 6rem;">
        <div style="margin-bottom:2.5rem;">
          <span class="hero-eyebrow">✦ all posts ✦</span>
          <h1 style="font-family:var(--font-display);font-size:clamp(2rem,4vw,3rem);font-weight:300;color:var(--star-white);margin-top:1rem;">
            Observations
          </h1>
        </div>

        <div class="tag-filter" id="tag-filter">
          <button class="filter-tag active" data-tag="all">All</button>
          {allTags.map((tag) => (
            <button class="filter-tag" data-tag={tag}>{tag}</button>
          ))}
        </div>

        <p class="section-label" id="post-count">{posts.length} posts</p>

        <div id="posts-list">
          {posts.map((post) => (
            <a
              href={`/blog/${post.slug}/`}
              class="post-item"
              data-tags={(post.data.tags ?? []).join(',')}
            >
              <div class="pi-date">
                <FormattedDate date={post.data.pubDate} />
              </div>
              <div class="pi-body">
                <h2 class="pi-title">{post.data.title}</h2>
                {post.data.description && (
                  <p class="pi-desc">{post.data.description}</p>
                )}
                {post.data.tags && (
                  <div class="pi-tags">
                    {post.data.tags.map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <span class="pi-read-time">{readingTime(post.body)} min read</span>
            </a>
          ))}
        </div>

        <p id="no-results">No posts found for this tag.</p>
      </section>
    </main>
    <Footer />

    <script>
      const buttons = document.querySelectorAll('.filter-tag');
      const items = document.querySelectorAll('.post-item');
      const countEl = document.getElementById('post-count');
      const noResults = document.getElementById('no-results');

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          buttons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const tag = btn.dataset.tag;
          let visible = 0;
          items.forEach(item => {
            const tags = item.dataset.tags ? item.dataset.tags.split(',') : [];
            const show = tag === 'all' || tags.includes(tag);
            item.classList.toggle('hidden', !show);
            if (show) visible++;
          });
          countEl.textContent = visible + (visible === 1 ? ' post' : ' posts');
          noResults.style.display = visible === 0 ? 'block' : 'none';
        });
      });
    </script>
  </body>
</html>