---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getReadingTime } from '../../utils/readingTime';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Collect all unique tags across all posts
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`All Posts — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
			}

			/* ── Page header ──────────────────────────────────────── */
			.page-header {
				border-bottom: 2px solid rgb(var(--black));
				padding-bottom: 1.2rem;
				margin-bottom: 1.8rem;
			}
			.page-header h1 {
				font-size: 1.3rem;
				margin: 0 0 0.2rem 0;
				letter-spacing: -0.01em;
			}
			.post-count {
				font-size: 0.78rem;
				color: rgb(var(--gray));
			}

			/* ── Tag filter bar ───────────────────────────────────── */
			.tag-bar {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin-bottom: 2rem;
				align-items: center;
			}
			.tag-bar-label {
				font-size: 0.65rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin-right: 0.3rem;
			}
			.tag-btn {
				font-size: 0.68rem;
				font-weight: 500;
				letter-spacing: 0.04em;
				color: rgb(var(--gray));
				background: rgb(var(--gray-light));
				border: none;
				border-radius: 2px;
				padding: 3px 8px;
				cursor: pointer;
				transition: background 0.12s, color 0.12s;
				font-family: inherit;
			}
			.tag-btn::before {
				content: '#';
				opacity: 0.5;
			}
			.tag-btn:hover,
			.tag-btn.active {
				background: var(--accent);
				color: white;
			}
			.tag-btn.active::before {
				opacity: 0.8;
			}
			.tag-btn[data-tag="all"] {
				background: rgb(var(--black));
				color: white;
			}
			.tag-btn[data-tag="all"]::before {
				content: '';
			}
			.tag-btn[data-tag="all"].active {
				background: var(--accent);
			}

			/* ── Search ───────────────────────────────────────────── */
			.search-row {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				margin-bottom: 1.6rem;
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 1rem;
			}
			.search-icon {
				color: rgb(var(--gray));
				flex-shrink: 0;
				width: 14px;
				height: 14px;
			}
			.search-input {
				flex: 1;
				border: none;
				border-bottom: 1px solid rgb(var(--gray-light));
				background: transparent;
				font-size: 0.85rem;
				font-family: inherit;
				color: rgb(var(--gray-dark));
				padding: 4px 2px;
				outline: none;
				transition: border-color 0.15s;
				max-width: 320px;
			}
			.search-input::placeholder {
				color: rgb(var(--gray));
				opacity: 0.7;
			}
			.search-input:focus {
				border-bottom-color: var(--accent);
			}

			/* ── Post list ────────────────────────────────────────── */
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-item {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-item[data-hidden="true"] {
				display: none;
			}
			.post-link {
				display: grid;
				grid-template-columns: 1fr auto;
				gap: 0.5rem 1.5rem;
				align-items: start;
				padding: 1.2rem 0;
				text-decoration: none;
				color: inherit;
			}
			.post-link:hover .post-title {
				color: var(--accent);
			}
			.post-content {
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}
			.post-title {
				font-size: 1rem;
				font-weight: 700;
				line-height: 1.3;
				margin: 0;
				color: rgb(var(--black));
				transition: color 0.15s;
			}
			.post-desc {
				font-size: 0.84rem;
				color: rgb(var(--gray));
				line-height: 1.5;
				margin: 0;
			}
			.post-tags {
				display: flex;
				gap: 0.3rem;
				flex-wrap: wrap;
				margin-top: 0.35rem;
			}
			.tag {
				font-size: 0.67rem;
				font-weight: 500;
				letter-spacing: 0.04em;
				color: rgb(var(--gray));
				background: rgb(var(--gray-light));
				border-radius: 2px;
				padding: 2px 6px;
				text-decoration: none;
				transition: background 0.12s, color 0.12s;
				cursor: pointer;
				border: none;
				font-family: inherit;
			}
			.tag::before {
				content: '#';
				opacity: 0.5;
			}
			.tag:hover {
				background: var(--accent);
				color: white;
			}
			.post-aside {
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				gap: 0.2rem;
				white-space: nowrap;
				padding-top: 0.1rem;
			}
			.post-date {
				font-size: 0.75rem;
				color: rgb(var(--gray));
			}
			.post-read {
				font-size: 0.7rem;
				color: rgb(var(--gray));
				opacity: 0.75;
			}

			.no-results {
				display: none;
				font-size: 0.85rem;
				color: rgb(var(--gray));
				padding: 2rem 0;
			}
			.no-results.visible {
				display: block;
			}

			@media (max-width: 600px) {
				.post-link {
					grid-template-columns: 1fr;
				}
				.post-aside {
					flex-direction: row;
					gap: 0.6rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>All Posts</h1>
				<p class="post-count">{posts.length} dispatches from the void</p>
			</div>

			<!-- Search bar -->
			<div class="search-row">
				<svg class="search-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
					<circle cx="6.5" cy="6.5" r="4.5"/>
					<path d="m10 10 3.5 3.5" stroke-linecap="round"/>
				</svg>
				<input
					id="blog-search"
					class="search-input"
					type="search"
					placeholder="Search by title, tag…"
					aria-label="Search posts"
					autocomplete="off"
				/>
			</div>

			<!-- Tag filter bar -->
			{allTags.length > 0 && (
				<div class="tag-bar" id="tag-bar">
					<span class="tag-bar-label">Filter:</span>
					<button class="tag-btn active" data-tag="all">All</button>
					{allTags.map((tag) => (
						<button class="tag-btn" data-tag={tag}>{tag}</button>
					))}
				</div>
			)}

			<ul class="post-list" id="post-list">
				{posts.map((post) => (
					<li
						class="post-item"
						data-title={post.data.title.toLowerCase()}
						data-tags={post.data.tags.join(' ').toLowerCase()}
					>
						<a class="post-link" href={`/blog/${post.id}/`}>
							<div class="post-content">
								<h2 class="post-title">{post.data.title}</h2>
								<p class="post-desc">{post.data.description}</p>
								{post.data.tags.length > 0 && (
									<div class="post-tags">
										{post.data.tags.map((tag) => (
											<span class="tag" data-filter-tag={tag}>{tag}</span>
										))}
									</div>
								)}
							</div>
							<div class="post-aside">
								<span class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
								<span class="post-read">
									{getReadingTime(post.body ?? '')}
								</span>
							</div>
						</a>
					</li>
				))}
			</ul>
			<p class="no-results" id="no-results">No posts match your filter.</p>
		</main>
		<Footer />

		<script>
			const searchInput = document.getElementById('blog-search') as HTMLInputElement;
			const tagBar = document.getElementById('tag-bar');
			const items = document.querySelectorAll<HTMLElement>('.post-item');
			const noResults = document.getElementById('no-results')!;
			let activeTag = 'all';

			function applyFilters() {
				const query = searchInput?.value.trim().toLowerCase() ?? '';
				let visible = 0;
				items.forEach((item) => {
					const title = item.dataset.title ?? '';
					const tags = item.dataset.tags ?? '';
					const matchesSearch = !query || title.includes(query) || tags.includes(query);
					const matchesTag = activeTag === 'all' || tags.split(' ').includes(activeTag.toLowerCase());
					const show = matchesSearch && matchesTag;
					item.dataset.hidden = show ? 'false' : 'true';
					if (show) visible++;
				});
				noResults.classList.toggle('visible', visible === 0);
			}

			// Search
			searchInput?.addEventListener('input', applyFilters);

			// Tag buttons
			tagBar?.addEventListener('click', (e) => {
				const btn = (e.target as HTMLElement).closest<HTMLElement>('.tag-btn');
				if (!btn) return;
				activeTag = btn.dataset.tag ?? 'all';
				tagBar.querySelectorAll('.tag-btn').forEach((b) => b.classList.remove('active'));
				btn.classList.add('active');
				applyFilters();
			});

			// Clicking a tag pill inside a post card also filters
			document.querySelectorAll<HTMLElement>('.tag[data-filter-tag]').forEach((pill) => {
				pill.addEventListener('click', (e) => {
					e.preventDefault();
					e.stopPropagation();
					activeTag = pill.dataset.filterTag ?? 'all';
					tagBar?.querySelectorAll('.tag-btn').forEach((b) => {
						b.classList.toggle('active', (b as HTMLElement).dataset.tag === activeTag);
					});
					applyFilters();
					window.scrollTo({ top: 0, behavior: 'smooth' });
				});
			});

			// Activate tag from URL param (?tag=Cosmology)
			const urlTag = new URLSearchParams(window.location.search).get('tag');
			if (urlTag) {
				activeTag = urlTag;
				tagBar?.querySelectorAll<HTMLElement>('.tag-btn').forEach((b) => {
					b.classList.toggle('active', b.dataset.tag === urlTag);
				});
				applyFilters();
			}
		</script>
	</body>
</html>