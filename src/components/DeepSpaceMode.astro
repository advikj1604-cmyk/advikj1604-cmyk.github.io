---
---

<button class="dsm-toggle" id="dsm-toggle" title="Toggle Deep Space Mode" transition:persist>
  <span class="dsm-icon">✦</span>
  <span class="dsm-label">Deep Space</span>
</button>

<style>
  .dsm-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.35em 0.8em;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    z-index: 10;
  }
  .dsm-toggle:hover { border-color: var(--accent-gold); color: var(--accent-gold); }
  .dsm-toggle.active {
    border-color: var(--accent-gold);
    color: var(--accent-gold);
    background: rgba(200,169,110,0.06);
    animation: pulse-gold 2.5s infinite;
  }
  @keyframes pulse-gold {
    0%,100% { box-shadow: 0 0 6px rgba(200,169,110,0.15); }
    50%      { box-shadow: 0 0 16px rgba(200,169,110,0.35); }
  }
</style>

<script>
declare global {
  interface Window {
    __dsmCanvas?: HTMLCanvasElement;
    __dsmState?: DsmState;
    __dsmBound?: boolean;
  }
}

interface Star {
  ox: number; oy: number; drawX: number; drawY: number;
  size: number; op: number; tw: number; twS: number;
  layer: number; c: number[];
}
interface Shooter {
  x: number; y: number; vx: number; vy: number;
  op: number; trail: {x:number;y:number}[];
}
interface DsmState {
  active: boolean; frame: number; animId: number;
  W: number; H: number;
  mx: number; my: number; tmx: number; tmy: number;
  stars: Star[]; shooters: Shooter[]; lastShooter: number;
  BHX: number; BHY: number; BH_TX: number; BH_TY: number;
  bhPhase: 'visible'|'exiting'|'offscreen'|'entering';
  bhTimer: number; bhOffTimer: number;
  PSX: number; PSY: number; lastPulse: number; pulseFlash: number;
  gwR: number; gwX: number; gwY: number; gwOp: number; gwLast: number;
  trail: {x:number;y:number;op:number}[];
}

const rand = (a: number, b: number) => a + Math.random() * (b - a);
const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
const BH_R = 13; const LO = 160; const LI = 20; const PR = 20;
const STAR_COLORS = [[200,220,255],[255,240,200],[255,200,180],[180,200,255],[255,255,255],[220,180,255]];

// ── Canvas lives on <html>, survives Astro body swaps ─────────────────────
if (!window.__dsmCanvas) {
  const cv = document.createElement('canvas');
  Object.assign(cv.style, {
    position:'fixed', inset:'0', pointerEvents:'none',
    zIndex:'-1', opacity:'0', transition:'opacity 1.2s ease',
  });
  document.documentElement.appendChild(cv);
  window.__dsmCanvas = cv;
}

if (!window.__dsmState) {
  window.__dsmState = {
    active:false, frame:0, animId:0,
    W:0, H:0, mx:-9999, my:-9999, tmx:-9999, tmy:-9999,
    stars:[], shooters:[], lastShooter:0,
    BHX:0, BHY:0, BH_TX:0, BH_TY:0,
    bhPhase:'visible', bhTimer:0, bhOffTimer:0,
    PSX:0, PSY:0, lastPulse:0, pulseFlash:0,
    gwR:0, gwX:0, gwY:0, gwOp:0, gwLast:-9999,
    trail:[],
  };
}

// Global listeners registered only once
if (!window.__dsmBound) {
  window.__dsmBound = true;
  window.addEventListener('mousemove', e => {
    window.__dsmState!.tmx = e.clientX;
    window.__dsmState!.tmy = e.clientY;
  });
  window.addEventListener('resize', () => { if (window.__dsmState?.active) initStars(); });
  // Pause when tab hidden, resume when visible — do NOT deactivate
  document.addEventListener('visibilitychange', () => {
    const st = window.__dsmState!;
    if (document.hidden) {
      cancelAnimationFrame(st.animId);
    } else if (st.active) {
      st.animId = requestAnimationFrame(loop);
    }
  });
}

const cv  = window.__dsmCanvas!;
const ctx = cv.getContext('2d')!;
const s   = window.__dsmState!;

function initStars() {
  s.W = cv.width  = window.innerWidth;
  s.H = cv.height = window.innerHeight;
  s.PSX = s.W * 0.12; s.PSY = s.H * 0.80;
  // Always reset BH position on init so it moves after navigation
  s.BHX = s.BH_TX = rand(s.W*0.80, s.W-60);
  s.BHY = s.BH_TY = rand(50, s.H*0.20);
  s.bhPhase = 'visible';
  s.bhTimer = Math.round(rand(400, 700));
  s.stars = [];
  for (let layer=1; layer<=3; layer++) {
    const count = layer===1?300:layer===2?130:45;
    for (let i=0; i<count; i++) {
      const c = STAR_COLORS[Math.floor(rand(0,6))];
      s.stars.push({
        ox:rand(0,s.W), oy:rand(0,s.H), drawX:0, drawY:0,
        size: layer===1?rand(0.2,0.6):layer===2?rand(0.6,1.2):rand(1.2,2.2),
        op:   layer===1?rand(0.12,0.38):layer===2?rand(0.22,0.55):rand(0.4,0.75),
        tw:rand(0,Math.PI*2), twS:rand(0.004,0.02), layer, c,
      });
    }
  }
}

function pickBHTarget() {
  const { W, H } = s;
  const pad = 55;
  if (Math.random() < 0.22) {
    s.bhPhase = 'exiting';
    const edge = Math.floor(rand(0,4));
    if      (edge===0){s.BH_TX=rand(W*0.2,W*0.8);s.BH_TY=-70;}
    else if (edge===1){s.BH_TX=W+70;s.BH_TY=rand(H*0.2,H*0.8);}
    else if (edge===2){s.BH_TX=rand(W*0.2,W*0.8);s.BH_TY=H+70;}
    else              {s.BH_TX=-70;s.BH_TY=rand(H*0.2,H*0.8);}
    return;
  }
  if (Math.random() < 0.60) {
    const corner = Math.floor(rand(0,4));
    const lx=pad,rx=W-pad,ty=pad,by=H-pad,cx=W*0.18,cy=H*0.18;
    if      (corner===0){s.BH_TX=rand(lx,lx+cx);s.BH_TY=rand(ty,ty+cy);}
    else if (corner===1){s.BH_TX=rand(rx-cx,rx);s.BH_TY=rand(ty,ty+cy);}
    else if (corner===2){s.BH_TX=rand(lx,lx+cx);s.BH_TY=rand(by-cy,by);}
    else                {s.BH_TX=rand(rx-cx,rx);s.BH_TY=rand(by-cy,by);}
  } else {
    const edge=Math.floor(rand(0,4));
    if      (edge===0){s.BH_TX=rand(W*0.25,W*0.75);s.BH_TY=rand(pad,H*0.15);}
    else if (edge===1){s.BH_TX=rand(W*0.85,W-pad);s.BH_TY=rand(H*0.25,H*0.75);}
    else if (edge===2){s.BH_TX=rand(W*0.25,W*0.75);s.BH_TY=rand(H*0.85,H-pad);}
    else              {s.BH_TX=rand(pad,W*0.15);s.BH_TY=rand(H*0.25,H*0.75);}
  }
  s.bhPhase='visible'; s.bhTimer=Math.round(rand(500,900));
}

function moveBH(speed: number): boolean {
  const dx=s.BH_TX-s.BHX, dy=s.BH_TY-s.BHY, d=Math.hypot(dx,dy);
  if (d<=speed){s.BHX=s.BH_TX;s.BHY=s.BH_TY;return true;}
  s.BHX+=(dx/d)*speed; s.BHY+=(dy/d)*speed; return false;
}

function updateBH() {
  if (s.bhPhase==='visible'){
    moveBH(0.45); s.bhTimer--;
    if (s.bhTimer<=0) pickBHTarget();
  } else if (s.bhPhase==='exiting'){
    if (moveBH(0.80)){
      const edge=Math.floor(rand(0,4));
      if      (edge===0){s.BHX=rand(s.W*0.2,s.W*0.8);s.BHY=-60;}
      else if (edge===1){s.BHX=s.W+60;s.BHY=rand(s.H*0.2,s.H*0.8);}
      else if (edge===2){s.BHX=rand(s.W*0.2,s.W*0.8);s.BHY=s.H+60;}
      else              {s.BHX=-60;s.BHY=rand(s.H*0.2,s.H*0.8);}
      s.bhPhase='offscreen'; s.bhOffTimer=Math.round(rand(80,180)); pickBHTarget();
    }
  } else if (s.bhPhase==='offscreen'){
    s.bhOffTimer--; if (s.bhOffTimer<=0) s.bhPhase='entering';
  } else if (s.bhPhase==='entering'){
    if (moveBH(0.80)){s.bhPhase='visible';s.bhTimer=Math.round(rand(500,900));}
  }
}

function applyLensing(sx: number, sy: number) {
  const dx=sx-s.BHX, dy=sy-s.BHY, r=Math.sqrt(dx*dx+dy*dy);
  if (r<1||r<BH_R*1.5) return null;
  if (r<LO){
    const strength=Math.pow(LI/r,1.8)*LO*0.55;
    const ang=Math.atan2(dy,dx);
    return {x:s.BHX+Math.cos(ang)*(r+strength),y:s.BHY+Math.sin(ang)*(r+strength),r};
  }
  return {x:sx,y:sy,r};
}

function drawStars() {
  const cx=s.W/2, cy=s.H/2;
  s.mx=lerp(s.mx,s.tmx,0.08); s.my=lerp(s.my,s.tmy,0.08);
  const ddx=s.tmx>-999?(s.mx-cx)/cx:0;
  const ddy=s.tmx>-999?(s.my-cy)/cy:0;
  for (const st of s.stars) {
    const spd=st.layer*0.018;
    let px=((st.ox+ddx*spd*s.W*10)%s.W+s.W)%s.W;
    let py=((st.oy+ddy*spd*s.H*10)%s.H+s.H)%s.H;
    const lens=applyLensing(px,py);
    if (!lens) continue;
    st.drawX=lens.x; st.drawY=lens.y;
    st.tw+=st.twS;
    const bOp=Math.max(0,Math.min(1,st.op*(0.55+0.45*Math.sin(st.tw))));
    const mag=lens.r<LO*0.7?1+(1-lens.r/(LO*0.7))*1.6:1;
    const fOp=Math.min(1,bOp*mag);
    const [r,g,b]=st.c;
    if (st.size>1.0||mag>1.3){
      const gr=st.size*(2.2+mag);
      const gg=ctx.createRadialGradient(st.drawX,st.drawY,0,st.drawX,st.drawY,gr);
      gg.addColorStop(0,`rgba(${r},${g},${b},${fOp*0.28})`);
      gg.addColorStop(1,`rgba(${r},${g},${b},0)`);
      ctx.beginPath();ctx.arc(st.drawX,st.drawY,gr,0,Math.PI*2);
      ctx.fillStyle=gg;ctx.fill();
    }
    ctx.beginPath();ctx.arc(st.drawX,st.drawY,st.size,0,Math.PI*2);
    ctx.fillStyle=`rgba(${r},${g},${b},${fOp})`;ctx.fill();
    if (st.size>1.8&&fOp>0.65){
      ctx.strokeStyle=`rgba(${r},${g},${b},${fOp*0.2})`;ctx.lineWidth=0.5;
      const arm=st.size*2.8;
      ctx.beginPath();
      ctx.moveTo(st.drawX-arm,st.drawY);ctx.lineTo(st.drawX+arm,st.drawY);
      ctx.moveTo(st.drawX,st.drawY-arm);ctx.lineTo(st.drawX,st.drawY+arm);
      ctx.stroke();
    }
  }
}

function drawBH() {
  const {BHX,BHY,frame}=s;
  if (BHX<-LO||BHX>s.W+LO||BHY<-LO||BHY>s.H+LO) return;
  const shadow=ctx.createRadialGradient(BHX,BHY,BH_R*2,BHX,BHY,LO*0.95);
  shadow.addColorStop(0,'rgba(0,0,0,0.82)');shadow.addColorStop(0.35,'rgba(0,0,0,0.38)');
  shadow.addColorStop(0.70,'rgba(0,0,0,0.10)');shadow.addColorStop(1,'rgba(0,0,0,0)');
  ctx.beginPath();ctx.arc(BHX,BHY,LO*0.95,0,Math.PI*2);ctx.fillStyle=shadow;ctx.fill();
  const rot=(frame*0.005)%(Math.PI*2);
  const tiltY=0.30;
  const bands:[number,number,[number,number,number],number,number][]=[
    [16,22,[255,255,230],0.82,0.38],[22,30,[255,200,80],0.65,0.28],
    [30,40,[255,130,30],0.45,0.18],[40,52,[200,70,15],0.25,0.10],[52,64,[110,35,8],0.12,0.04],
  ];
  const drawHalf=(front:boolean)=>{
    ctx.save();ctx.translate(BHX,BHY);ctx.rotate(rot);
    ctx.beginPath();
    if(front)ctx.rect(-150,-150,300,150);else ctx.rect(-150,0,300,150);
    ctx.clip();ctx.scale(1,tiltY);
    for (const [rIn,rOut,col,af,ab] of bands){
      const a=front?af:ab;const[rr,gg,bb]=col;
      const g2=ctx.createRadialGradient(0,0,rIn,0,0,rOut);
      g2.addColorStop(0,`rgba(${rr},${gg},${bb},0)`);
      g2.addColorStop(0.3,`rgba(${rr},${gg},${bb},${a})`);
      g2.addColorStop(0.65,`rgba(${rr},${gg},${bb},${a*0.55})`);
      g2.addColorStop(1,`rgba(${rr},${gg},${bb},0)`);
      ctx.beginPath();ctx.arc(0,0,rOut,0,Math.PI*2);ctx.fillStyle=g2;ctx.fill();
    }
    ctx.restore();
  };
  drawHalf(false);
  const pr=ctx.createRadialGradient(BHX,BHY,PR-2,BHX,BHY,PR+5);
  pr.addColorStop(0,'rgba(255,245,190,0)');pr.addColorStop(0.30,'rgba(255,255,220,0.92)');
  pr.addColorStop(0.60,'rgba(255,220,110,0.48)');pr.addColorStop(1,'rgba(255,160,40,0)');
  ctx.beginPath();ctx.arc(BHX,BHY,PR+5,0,Math.PI*2);ctx.fillStyle=pr;ctx.fill();
  ctx.beginPath();ctx.arc(BHX,BHY,BH_R,0,Math.PI*2);ctx.fillStyle='#000';ctx.fill();
  drawHalf(true);
  ctx.beginPath();ctx.arc(BHX,BHY,BH_R,0,Math.PI*2);ctx.fillStyle='#000';ctx.fill();
}

function drawPulsar() {
  const{PSX:px,PSY:py,frame:fr}=s;
  if(fr-s.lastPulse>200){s.lastPulse=fr;s.pulseFlash=1;}
  s.pulseFlash=Math.max(0,s.pulseFlash-0.02);
  const ang=fr*0.04;
  for(const off of[0,Math.PI]){
    const ex=px+Math.cos(ang+off)*120,ey=py+Math.sin(ang+off)*120;
    const bm=ctx.createLinearGradient(px,py,ex,ey);
    bm.addColorStop(0,`rgba(180,220,255,${0.18+s.pulseFlash*0.35})`);
    bm.addColorStop(0.5,`rgba(150,200,255,${0.07+s.pulseFlash*0.15})`);
    bm.addColorStop(1,'rgba(100,160,255,0)');
    ctx.beginPath();ctx.moveTo(px,py);ctx.lineTo(ex,ey);
    ctx.strokeStyle=bm;ctx.lineWidth=1.5+s.pulseFlash*2;ctx.stroke();
  }
  ctx.beginPath();ctx.arc(px,py,3,0,Math.PI*2);
  ctx.fillStyle=`rgba(200,230,255,${0.6+s.pulseFlash*0.4})`;ctx.fill();
}

function drawShooters() {
  for(let i=s.shooters.length-1;i>=0;i--){
    const sh=s.shooters[i];
    sh.trail.push({x:sh.x,y:sh.y});
    if(sh.trail.length>18)sh.trail.shift();
    sh.x+=sh.vx;sh.y+=sh.vy;sh.op-=0.018;
    if(sh.op<=0||sh.x>s.W+100){s.shooters.splice(i,1);continue;}
    for(let j=0;j<sh.trail.length;j++){
      const t=sh.trail[j],f=j/sh.trail.length;
      ctx.beginPath();ctx.arc(t.x,t.y,0.7*f,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,255,240,${sh.op*f*0.38})`;ctx.fill();
    }
    ctx.beginPath();ctx.arc(sh.x,sh.y,1.8,0,Math.PI*2);
    ctx.fillStyle=`rgba(255,255,255,${sh.op})`;ctx.fill();
  }
}

function drawGravWave() {
  if(s.frame-s.gwLast>rand(1400,2200)&&Math.random()<0.004){
    s.gwLast=s.frame;s.gwX=rand(s.W*0.2,s.W*0.8);s.gwY=rand(s.H*0.2,s.H*0.8);
    s.gwR=0;s.gwOp=0.5;
  }
  if(s.gwOp>0){
    s.gwR+=3.5;s.gwOp-=0.003;
    ctx.beginPath();ctx.arc(s.gwX,s.gwY,s.gwR,0,Math.PI*2);
    ctx.strokeStyle=`rgba(180,220,255,${s.gwOp*0.16})`;ctx.lineWidth=1.5;ctx.stroke();
  }
}

function drawTrail() {
  if(s.tmx<0)return;
  s.trail.push({x:s.tmx+rand(-3,3),y:s.tmy+rand(-3,3),op:0.8});
  if(s.trail.length>32)s.trail.shift();
  for(let i=0;i<s.trail.length;i++){
    const t=s.trail[i],f=i/s.trail.length;
    t.op-=0.028;if(t.op<=0)continue;
    ctx.beginPath();ctx.arc(t.x,t.y,0.9*f,0,Math.PI*2);
    ctx.fillStyle=`rgba(200,169,110,${t.op*f})`;ctx.fill();
  }
}

function loop() {
  if(!s.active)return;
  s.frame++;
  ctx.clearRect(0,0,s.W,s.H);
  updateBH();
  drawStars();drawBH();drawPulsar();drawShooters();drawGravWave();drawTrail();
  if(s.frame-s.lastShooter>rand(70,130)){
    s.shooters.push({x:rand(0,s.W*0.6),y:rand(0,s.H*0.4),vx:rand(5,10),vy:rand(1.5,4),op:1,trail:[]});
    s.lastShooter=s.frame;
  }
  s.animId=requestAnimationFrame(loop);
}

function bindBtn() {
  const btn=document.getElementById('dsm-toggle') as HTMLButtonElement|null;
  if(!btn)return;
  btn.classList.toggle('active',s.active);
  btn.onclick=()=>{
    s.active=!s.active;
    btn.classList.toggle('active',s.active);
    cv.style.opacity=s.active?'1':'0';
    if(s.active){
      initStars();
      cancelAnimationFrame(s.animId);
      s.animId=requestAnimationFrame(loop);
    } else {
      cancelAnimationFrame(s.animId);
      ctx.clearRect(0,0,s.W,s.H);
    }
  };
}

// Re-bind button on every Astro page load, keep canvas/state alive
document.addEventListener('astro:page-load', bindBtn);
bindBtn();

if(s.active){
  if(s.W!==window.innerWidth||s.H!==window.innerHeight)initStars();
  cv.style.opacity='1';
  cancelAnimationFrame(s.animId);
  s.animId=requestAnimationFrame(loop);
}
</script>