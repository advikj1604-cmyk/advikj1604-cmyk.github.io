---
---

<button class="dsm-toggle" id="dsm-toggle" title="Toggle Deep Space Mode">
  <span class="dsm-icon">✦</span>
  <span class="dsm-label">Deep Space</span>
</button>

<canvas id="dsm-canvas" class="dsm-canvas"></canvas>

<style>
  .dsm-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.35em 0.8em;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    z-index: 10;
  }
  .dsm-toggle:hover { border-color: var(--accent-gold); color: var(--accent-gold); }
  .dsm-toggle.active {
    border-color: var(--accent-gold);
    color: var(--accent-gold);
    background: rgba(200,169,110,0.06);
    animation: pulse-gold 2.5s infinite;
  }
  @keyframes pulse-gold {
    0%,100% { box-shadow: 0 0 6px rgba(200,169,110,0.15); }
    50%      { box-shadow: 0 0 16px rgba(200,169,110,0.35); }
  }
  .dsm-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    opacity: 0;
    transition: opacity 1.2s ease;
  }
  .dsm-canvas.active { opacity: 1; }
</style>

<script>
// ── Persist active state across Astro page navigations ─────────────────────
// We keep the canvas + state alive by hoisting to window so Astro's
// view-transitions don't destroy it. The button re-binds each page load.

declare global {
  interface Window {
    __dsm__: {
      active: boolean;
      canvas: HTMLCanvasElement;
      ctx: CanvasRenderingContext2D;
      frame: number;
      animFrame: number;
      stars: Star[];
      shooters: Shooter[];
      W: number; H: number;
      mx: number; my: number;
      tmx: number; tmy: number;
      BHX: number; BHY: number;
      BH_TX: number; BH_TY: number;
      bhTimer: number;
      bhPhase: 'visible'|'exiting'|'offscreen'|'entering';
      bhOffTimer: number;
      lastShooter: number;
      lastPulse: number; pulseFlash: number;
      PSX: number; PSY: number;
      gravWaveR: number; gravWaveX: number; gravWaveY: number;
      gravWaveOp: number; lastGravWave: number;
      cursorTrail: {x:number;y:number;op:number}[];
    } | undefined;
  }
}

interface Star {
  ox: number; oy: number;
  drawX: number; drawY: number;
  size: number; op: number;
  tw: number; twS: number;
  layer: number; c: number[];
}
interface Shooter {
  x: number; y: number; vx: number; vy: number;
  op: number; trail: { x: number; y: number }[];
}

const rand = (a: number, b: number) => a + Math.random() * (b - a);
const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

const BH_RADIUS     = 13;
const LENS_OUTER    = 160;
const LENS_INNER    = 20;
const PHOTON_RING_R = 20;

const STAR_COLORS = [
  [200, 220, 255], [255, 240, 200], [255, 200, 180],
  [180, 200, 255], [255, 255, 255], [220, 180, 255],
];

// ── Bootstrap global state once ────────────────────────────────────────────
if (!window.__dsm__) {
  const cv = document.createElement('canvas');
  cv.id = 'dsm-canvas-global';
  cv.style.cssText = 'position:fixed;inset:0;pointer-events:none;z-index:-1;opacity:0;transition:opacity 1.2s ease;';
  document.body.appendChild(cv);
  window.__dsm__ = {
    active: false,
    canvas: cv,
    ctx: cv.getContext('2d')!,
    frame: 0, animFrame: 0,
    stars: [], shooters: [],
    W: 0, H: 0,
    mx: -9999, my: -9999,
    tmx: -9999, tmy: -9999,
    BHX: 0, BHY: 0, BH_TX: 0, BH_TY: 0,
    bhTimer: 0,
    bhPhase: 'visible',
    bhOffTimer: 0,
    lastShooter: 0,
    lastPulse: 0, pulseFlash: 0,
    PSX: 0, PSY: 0,
    gravWaveR: 0, gravWaveX: 0, gravWaveY: 0, gravWaveOp: 0, lastGravWave: -9999,
    cursorTrail: [],
  };
  // Global listeners — attached once, survive nav
  window.addEventListener('mousemove', e => { window.__dsm__!.tmx = e.clientX; window.__dsm__!.tmy = e.clientY; });
  window.addEventListener('resize', () => { if (window.__dsm__?.active) reinit(); });
  document.addEventListener('visibilitychange', () => {
    const d = window.__dsm__!;
    if (document.hidden) cancelAnimationFrame(d.animFrame);
    else if (d.active) d.animFrame = requestAnimationFrame(drawLoop);
  });
}

const d = window.__dsm__!;

// ── Re-bind the in-page button each Astro page load ────────────────────────
function bindButton() {
  const btn = document.getElementById('dsm-toggle') as HTMLButtonElement | null;
  if (!btn) return;
  // Sync button visual with persisted active state
  btn.classList.toggle('active', d.active);
  btn.addEventListener('click', () => {
    d.active = !d.active;
    btn.classList.toggle('active', d.active);
    d.canvas.style.opacity = d.active ? '1' : '0';
    if (d.active) { reinit(); d.animFrame = requestAnimationFrame(drawLoop); }
    else { cancelAnimationFrame(d.animFrame); d.ctx.clearRect(0, 0, d.W, d.H); }
  });
}

// ── Reinit (resize / first start) — keeps frame counter ───────────────────
function reinit() {
  d.W = d.canvas.width  = window.innerWidth;
  d.H = d.canvas.height = window.innerHeight;
  d.PSX = d.W * 0.12; d.PSY = d.H * 0.80;

  // Only reset BH if it's at 0,0 (first run)
  if (d.BHX === 0 && d.BHY === 0) {
    d.BHX = d.BH_TX = rand(d.W * 0.15, d.W * 0.85);
    d.BHY = d.BH_TY = rand(d.H * 0.15, d.H * 0.85);
    d.bhPhase = 'visible';
    d.bhTimer = Math.round(rand(300, 600));
  }

  d.stars = [];
  // Sparse, distant-feeling star field — low counts, low opacity ceiling
  const counts = [300, 130, 45];
  for (let layer = 1; layer <= 3; layer++) {
    for (let i = 0; i < counts[layer - 1]; i++) {
      const c = STAR_COLORS[Math.floor(rand(0, 6))];
      d.stars.push({
        ox: rand(0, d.W), oy: rand(0, d.H),
        drawX: 0, drawY: 0,
        size:  layer === 1 ? rand(0.2, 0.6) : layer === 2 ? rand(0.6, 1.2) : rand(1.2, 2.2),
        op:    layer === 1 ? rand(0.12, 0.38) : layer === 2 ? rand(0.22, 0.55) : rand(0.4, 0.75),
        tw: rand(0, Math.PI * 2), twS: rand(0.004, 0.02),
        layer, c,
      });
    }
  }
}

// ── Black hole wandering — corners, edges, occasional off-screen ───────────
function pickNextBHTarget() {
  const { W, H } = d;
  const margin = 60;

  // Weighted zones: 50% corner region, 30% edge region, 20% off-screen pop
  const roll = Math.random();

  if (roll < 0.20) {
    // Go off-screen — pick a random edge and overshoot
    d.bhPhase = 'exiting';
    const edge = Math.floor(rand(0, 4));
    if      (edge === 0) { d.BH_TX = rand(W*0.2, W*0.8); d.BH_TY = -120; }
    else if (edge === 1) { d.BH_TX = W + 120;             d.BH_TY = rand(H*0.2, H*0.8); }
    else if (edge === 2) { d.BH_TX = rand(W*0.2, W*0.8); d.BH_TY = H + 120; }
    else                 { d.BH_TX = -120;                d.BH_TY = rand(H*0.2, H*0.8); }
    d.bhTimer = Math.round(rand(400, 700));
  } else if (roll < 0.70) {
    // Corner region — within ~25% of a corner
    d.bhPhase = 'visible';
    const corner = Math.floor(rand(0, 4));
    const cx = corner % 2 === 0 ? margin : W - margin;
    const cy = corner < 2 ? margin : H - margin;
    d.BH_TX = cx + rand(-W*0.12, W*0.12);
    d.BH_TY = cy + rand(-H*0.12, H*0.12);
    d.BH_TX = Math.max(margin, Math.min(W - margin, d.BH_TX));
    d.BH_TY = Math.max(margin, Math.min(H - margin, d.BH_TY));
    d.bhTimer = Math.round(rand(350, 650));
  } else {
    // Edge region — near one side but not a corner
    d.bhPhase = 'visible';
    const edge = Math.floor(rand(0, 4));
    if      (edge === 0) { d.BH_TX = rand(W*0.25, W*0.75); d.BH_TY = rand(margin, H*0.2); }
    else if (edge === 1) { d.BH_TX = rand(W*0.8, W-margin); d.BH_TY = rand(H*0.25, H*0.75); }
    else if (edge === 2) { d.BH_TX = rand(W*0.25, W*0.75); d.BH_TY = rand(H*0.8, H-margin); }
    else                 { d.BH_TX = rand(margin, W*0.2);   d.BH_TY = rand(H*0.25, H*0.75); }
    d.bhTimer = Math.round(rand(300, 550));
  }
}

// Constant-velocity mover — call each frame, returns true when arrived
function moveBHToward(speed: number): boolean {
  const dx = d.BH_TX - d.BHX, dy = d.BH_TY - d.BHY;
  const dist = Math.hypot(dx, dy);
  if (dist < speed) { d.BHX = d.BH_TX; d.BHY = d.BH_TY; return true; }
  d.BHX += (dx / dist) * speed;
  d.BHY += (dy / dist) * speed;
  return false;
}

function updateBlackHole() {
  const SPEED_VISIBLE  = 0.35; // px/frame on-screen drift — very slow
  const SPEED_TRANSIT  = 0.55; // px/frame when exiting/entering

  if (d.bhPhase === 'exiting') {
    if (moveBHToward(SPEED_TRANSIT)) {
      d.bhPhase = 'offscreen';
      d.bhOffTimer = Math.round(rand(90, 210));
      // Teleport to a random entry point on a different edge
      const edge = Math.floor(rand(0, 4));
      if      (edge === 0) { d.BHX = rand(d.W*0.2, d.W*0.8); d.BHY = -60; }
      else if (edge === 1) { d.BHX = d.W + 60;                d.BHY = rand(d.H*0.2, d.H*0.8); }
      else if (edge === 2) { d.BHX = rand(d.W*0.2, d.W*0.8); d.BHY = d.H + 60; }
      else                 { d.BHX = -60;                     d.BHY = rand(d.H*0.2, d.H*0.8); }
      pickNextBHTarget();
    }
  } else if (d.bhPhase === 'offscreen') {
    d.bhOffTimer--;
    if (d.bhOffTimer <= 0) d.bhPhase = 'entering';
  } else if (d.bhPhase === 'entering') {
    if (moveBHToward(SPEED_TRANSIT)) {
      d.bhPhase = 'visible';
      d.bhTimer = Math.round(rand(400, 700));
    }
  } else {
    // visible — slow constant drift, then pick next waypoint
    moveBHToward(SPEED_VISIBLE);
    d.bhTimer--;
    if (d.bhTimer <= 0) pickNextBHTarget();
  }
}

// ── Lensing ────────────────────────────────────────────────────────────────
function applyLensing(sx: number, sy: number): { x: number; y: number; r: number } | null {
  const dx = sx - d.BHX, dy = sy - d.BHY;
  const r  = Math.sqrt(dx*dx + dy*dy);
  if (r < 1 || r < BH_RADIUS * 1.5) return null;
  const ang = Math.atan2(dy, dx);
  if (r < LENS_OUTER) {
    const strength = Math.pow(LENS_INNER / r, 1.8) * LENS_OUTER * 0.55;
    return { x: d.BHX + Math.cos(ang)*(r+strength), y: d.BHY + Math.sin(ang)*(r+strength), r };
  }
  return { x: sx, y: sy, r };
}

// ── Draw stars ─────────────────────────────────────────────────────────────
function drawStars() {
  const cx = d.W/2, cy = d.H/2;
  d.mx = lerp(d.mx, d.tmx, 0.08);
  d.my = lerp(d.my, d.tmy, 0.08);
  const ddx = d.tmx > -999 ? (d.mx - cx) / cx : 0;
  const ddy = d.tmx > -999 ? (d.my - cy) / cy : 0;
  const ctx = d.ctx;

  for (const s of d.stars) {
    const speed = s.layer * 0.018;
    let px = s.ox + ddx * speed * d.W * 10;
    let py = s.oy + ddy * speed * d.H * 10;
    px = ((px % d.W) + d.W) % d.W;
    py = ((py % d.H) + d.H) % d.H;

    const lens = applyLensing(px, py);
    if (!lens) continue;

    s.drawX = lens.x; s.drawY = lens.y;
    s.tw += s.twS;
    const baseOp  = Math.max(0, Math.min(1, s.op * (0.55 + 0.45 * Math.sin(s.tw))));
    const magBoost = lens.r < LENS_OUTER * 0.7 ? 1 + (1 - lens.r/(LENS_OUTER*0.7)) * 1.6 : 1;
    const finalOp  = Math.min(1, baseOp * magBoost);
    const [r, g, b] = s.c;

    if (s.size > 1.0 || magBoost > 1.3) {
      const gr = s.size * (2.2 + magBoost);
      const gg = ctx.createRadialGradient(s.drawX, s.drawY, 0, s.drawX, s.drawY, gr);
      gg.addColorStop(0, `rgba(${r},${g},${b},${finalOp*0.28})`);
      gg.addColorStop(1, `rgba(${r},${g},${b},0)`);
      ctx.beginPath(); ctx.arc(s.drawX, s.drawY, gr, 0, Math.PI*2);
      ctx.fillStyle = gg; ctx.fill();
    }
    ctx.beginPath(); ctx.arc(s.drawX, s.drawY, s.size, 0, Math.PI*2);
    ctx.fillStyle = `rgba(${r},${g},${b},${finalOp})`; ctx.fill();

    if (s.size > 1.8 && finalOp > 0.65) {
      ctx.strokeStyle = `rgba(${r},${g},${b},${finalOp*0.2})`;
      ctx.lineWidth = 0.5;
      const arm = s.size * 2.8;
      ctx.beginPath();
      ctx.moveTo(s.drawX-arm, s.drawY); ctx.lineTo(s.drawX+arm, s.drawY);
      ctx.moveTo(s.drawX, s.drawY-arm); ctx.lineTo(s.drawX, s.drawY+arm);
      ctx.stroke();
    }
  }
}

// ── Draw black hole ────────────────────────────────────────────────────────
function drawBlackHole() {
  const { BHX, BHY, frame } = d;
  const ctx = d.ctx;

  // Skip drawing when truly off-screen (saves work + avoids ghost glow)
  if (BHX < -LENS_OUTER || BHX > d.W+LENS_OUTER || BHY < -LENS_OUTER || BHY > d.H+LENS_OUTER) return;

  // ── 1. Gravitational darkening (wide soft shadow) ──
  const shadow = ctx.createRadialGradient(BHX, BHY, BH_RADIUS*2, BHX, BHY, LENS_OUTER*0.95);
  shadow.addColorStop(0,    'rgba(0,0,0,0.82)');
  shadow.addColorStop(0.35, 'rgba(0,0,0,0.40)');
  shadow.addColorStop(0.70, 'rgba(0,0,0,0.12)');
  shadow.addColorStop(1,    'rgba(0,0,0,0)');
  ctx.beginPath(); ctx.arc(BHX, BHY, LENS_OUTER*0.95, 0, Math.PI*2);
  ctx.fillStyle = shadow; ctx.fill();

  // ── 2. Accretion disk ─────────────────────────────────────────────────────
  // Rendered as a proper tilted ellipse (not scaled circle) so it looks 3-D.
  // Two clip passes: back half first, then event horizon, then front half on top.
  const diskRot = (frame * 0.005) % (Math.PI * 2);
  const tiltY   = 0.30; // vertical compression → tilt illusion

  // Disk band definitions: [inner-r, outer-r, [R,G,B], alpha-front, alpha-back]
  const bands: [number,number,[number,number,number],number,number][] = [
    [16, 22, [255,255,230], 0.82, 0.38],
    [22, 30, [255,200, 80], 0.65, 0.28],
    [30, 40, [255,130, 30], 0.45, 0.18],
    [40, 52, [200, 70, 15], 0.25, 0.10],
    [52, 64, [110, 35,  8], 0.12, 0.04],
  ];

  function drawDiskHalf(front: boolean) {
    ctx.save();
    ctx.translate(BHX, BHY);
    ctx.rotate(diskRot);
    // Clip to top half (front) or bottom half (back) in disk-local coords
    ctx.beginPath();
    if (front) ctx.rect(-150, -150, 300, 150);
    else       ctx.rect(-150,    0, 300, 150);
    ctx.clip();
    ctx.scale(1, tiltY);

    for (const [rIn, rOut, col, alphaF, alphaB] of bands) {
      const alpha = front ? alphaF : alphaB;
      const [rr,gg,bb] = col;
      // Soft band via radial gradient
      const g2 = ctx.createRadialGradient(0, 0, rIn, 0, 0, rOut);
      g2.addColorStop(0,    `rgba(${rr},${gg},${bb},0)`);
      g2.addColorStop(0.3,  `rgba(${rr},${gg},${bb},${alpha})`);
      g2.addColorStop(0.65, `rgba(${rr},${gg},${bb},${alpha*0.55})`);
      g2.addColorStop(1,    `rgba(${rr},${gg},${bb},0)`);
      ctx.beginPath(); ctx.arc(0, 0, rOut, 0, Math.PI*2);
      ctx.fillStyle = g2; ctx.fill();
    }
    ctx.restore();
  }

  drawDiskHalf(false); // back half behind BH

  // ── 3. Photon ring (tight bright ring right at photon sphere) ──
  const pr = ctx.createRadialGradient(BHX, BHY, PHOTON_RING_R-2, BHX, BHY, PHOTON_RING_R+5);
  pr.addColorStop(0,    'rgba(255,245,190,0)');
  pr.addColorStop(0.30, 'rgba(255,255,220,0.92)');
  pr.addColorStop(0.60, 'rgba(255,220,110,0.48)');
  pr.addColorStop(1,    'rgba(255,160, 40,0)');
  ctx.beginPath(); ctx.arc(BHX, BHY, PHOTON_RING_R+5, 0, Math.PI*2);
  ctx.fillStyle = pr; ctx.fill();

  // ── 4. Event horizon ──
  ctx.beginPath(); ctx.arc(BHX, BHY, BH_RADIUS, 0, Math.PI*2);
  ctx.fillStyle = '#000'; ctx.fill();

  drawDiskHalf(true); // front half in front of BH

  // ── 5. Re-stamp event horizon on top of front disk ──
  ctx.beginPath(); ctx.arc(BHX, BHY, BH_RADIUS, 0, Math.PI*2);
  ctx.fillStyle = '#000'; ctx.fill();

  // ── 6. Faint blue-white lensing corona ──
  const corona = ctx.createRadialGradient(BHX, BHY, PHOTON_RING_R+6, BHX, BHY, PHOTON_RING_R+24);
  corona.addColorStop(0,    'rgba(160,205,255,0)');
  corona.addColorStop(0.40, 'rgba(160,205,255,0.10)');
  corona.addColorStop(1,    'rgba(160,205,255,0)');
  ctx.beginPath(); ctx.arc(BHX, BHY, PHOTON_RING_R+24, 0, Math.PI*2);
  ctx.fillStyle = corona; ctx.fill();
}

// ── Pulsar ─────────────────────────────────────────────────────────────────
function drawPulsar() {
  const { PSX, PSY, frame } = d;
  const ctx = d.ctx;
  if (frame - d.lastPulse > 200) { d.lastPulse = frame; d.pulseFlash = 1; }
  d.pulseFlash = Math.max(0, d.pulseFlash - 0.02);
  const angle = frame * 0.04;
  for (const off of [0, Math.PI]) {
    const ex = PSX + Math.cos(angle+off)*120, ey = PSY + Math.sin(angle+off)*120;
    const beam = ctx.createLinearGradient(PSX, PSY, ex, ey);
    beam.addColorStop(0,   `rgba(180,220,255,${0.18+d.pulseFlash*0.35})`);
    beam.addColorStop(0.5, `rgba(150,200,255,${0.07+d.pulseFlash*0.15})`);
    beam.addColorStop(1,   'rgba(100,160,255,0)');
    ctx.beginPath(); ctx.moveTo(PSX,PSY); ctx.lineTo(ex,ey);
    ctx.strokeStyle = beam; ctx.lineWidth = 1.5+d.pulseFlash*2; ctx.stroke();
  }
  ctx.beginPath(); ctx.arc(PSX, PSY, 3, 0, Math.PI*2);
  ctx.fillStyle = `rgba(200,230,255,${0.6+d.pulseFlash*0.4})`; ctx.fill();
  if (d.pulseFlash > 0.4) {
    ctx.fillStyle = `rgba(150,200,255,${d.pulseFlash*0.02})`;
    ctx.fillRect(0, 0, d.W, d.H);
  }
}

// ── Shooting stars ─────────────────────────────────────────────────────────
function drawShooters() {
  const ctx = d.ctx;
  for (let i = d.shooters.length-1; i >= 0; i--) {
    const s = d.shooters[i];
    s.trail.push({x:s.x,y:s.y});
    if (s.trail.length > 18) s.trail.shift();
    s.x += s.vx; s.y += s.vy; s.op -= 0.018;
    if (s.op <= 0 || s.x > d.W+100) { d.shooters.splice(i,1); continue; }
    for (let j=0;j<s.trail.length;j++) {
      const t=s.trail[j], f=j/s.trail.length;
      ctx.beginPath(); ctx.arc(t.x,t.y,0.7*f,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,255,240,${s.op*f*0.38})`; ctx.fill();
    }
    ctx.beginPath(); ctx.arc(s.x,s.y,1.8,0,Math.PI*2);
    ctx.fillStyle=`rgba(255,255,255,${s.op})`; ctx.fill();
  }
}

// ── Grav wave ──────────────────────────────────────────────────────────────
function updateGravWave() {
  const ctx = d.ctx;
  if (d.frame - d.lastGravWave > rand(1400,2200) && Math.random() < 0.004) {
    d.lastGravWave = d.frame;
    d.gravWaveX = rand(d.W*0.2, d.W*0.8); d.gravWaveY = rand(d.H*0.2, d.H*0.8);
    d.gravWaveR = 0; d.gravWaveOp = 0.5;
  }
  if (d.gravWaveOp > 0) {
    d.gravWaveR  += 3.5; d.gravWaveOp -= 0.003;
    ctx.beginPath(); ctx.arc(d.gravWaveX, d.gravWaveY, d.gravWaveR, 0, Math.PI*2);
    ctx.strokeStyle = `rgba(180,220,255,${d.gravWaveOp*0.16})`; ctx.lineWidth=1.5; ctx.stroke();
  }
}

// ── Cursor trail ───────────────────────────────────────────────────────────
function drawCursorTrail() {
  const ctx = d.ctx;
  if (d.tmx < 0) return;
  d.cursorTrail.push({x:d.tmx+rand(-3,3),y:d.tmy+rand(-3,3),op:0.8});
  if (d.cursorTrail.length > 32) d.cursorTrail.shift();
  for (let i=0;i<d.cursorTrail.length;i++) {
    const t=d.cursorTrail[i], f=i/d.cursorTrail.length;
    t.op -= 0.028; if (t.op<=0) continue;
    ctx.beginPath(); ctx.arc(t.x,t.y,0.9*f,0,Math.PI*2);
    ctx.fillStyle=`rgba(200,169,110,${t.op*f})`; ctx.fill();
  }
}

// ── Main loop ──────────────────────────────────────────────────────────────
function drawLoop() {
  if (!d.active) return;
  d.frame++;
  d.ctx.clearRect(0, 0, d.W, d.H);

  updateBlackHole();
  drawStars();
  drawBlackHole();
  drawPulsar();
  drawShooters();
  updateGravWave();
  drawCursorTrail();

  if (d.frame - d.lastShooter > rand(70,130)) {
    d.shooters.push({x:rand(0,d.W*0.6),y:rand(0,d.H*0.4),vx:rand(5,10),vy:rand(1.5,4),op:1,trail:[]});
    d.lastShooter = d.frame;
  }
  d.animFrame = requestAnimationFrame(drawLoop);
}

// ── Run on every Astro page load ───────────────────────────────────────────
bindButton();
// If active when page loads (user navigated), make sure canvas is visible
// and loop is running (visibilitychange may have paused it)
if (d.active) {
  d.canvas.style.opacity = '1';
  // Resize canvas to new page dimensions
  if (d.W !== window.innerWidth || d.H !== window.innerHeight) reinit();
  cancelAnimationFrame(d.animFrame);
  d.animFrame = requestAnimationFrame(drawLoop);
}
</script>