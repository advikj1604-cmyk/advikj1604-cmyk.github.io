---
---

<button class="dsm-toggle" id="dsm-toggle" title="Toggle Deep Space Mode">
  <span class="dsm-icon">✦</span>
  <span class="dsm-label">Deep Space</span>
</button>

<canvas id="dsm-canvas" class="dsm-canvas"></canvas>

<style>
  .dsm-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.35em 0.8em;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    z-index: 10;
  }
  .dsm-toggle:hover { border-color: var(--accent-gold); color: var(--accent-gold); }
  .dsm-toggle.active {
    border-color: var(--accent-gold);
    color: var(--accent-gold);
    background: rgba(200,169,110,0.06);
    animation: pulse-gold 2.5s infinite;
  }
  @keyframes pulse-gold {
    0%,100% { box-shadow: 0 0 6px rgba(200,169,110,0.15); }
    50% { box-shadow: 0 0 16px rgba(200,169,110,0.35); }
  }
  .dsm-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    transition: opacity 1.2s ease;
  }
  .dsm-canvas.active { opacity: 1; }
</style>

<script>
const btn = document.getElementById('dsm-toggle')!;
const canvas = document.getElementById('dsm-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

let active = false;
let frame = 0;
let animFrame: number;
let W = 0, H = 0;
let mouseX = -9999, mouseY = -9999;
let targetMouseX = -9999, targetMouseY = -9999;

const rand = (a: number, b: number) => a + Math.random() * (b - a);
const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
const dist = (x1: number, y1: number, x2: number, y2: number) => Math.hypot(x2-x1, y2-y1);

// ── Types ─────────────────────────────────────────────────────────────────
interface Star {
  x: number; y: number; ox: number; oy: number;
  size: number; op: number; twinkle: number; twSpeed: number;
  color: string; layer: number;
}
interface Shooter {
  x: number; y: number; vx: number; vy: number;
  op: number; trail: {x:number;y:number}[]; active: boolean;
}

let stars: Star[] = [];
let shooters: Shooter[] = [];
let lastShooter = 0;
let lastGravWave = -9999;
let gravWaveR = 0;
let gravWaveX = 0;
let gravWaveY = 0;
let gravWaveOp = 0;

// Black hole position (top right area)
let bhx = 0, bhy = 0;
// Pulsar position (bottom left)
let psx = 0, psy = 0;
let pulseFrame = 0;
let lastPulse = 0;
let pulseFlash = 0;

const COLORS = [
  'rgba(200,220,255,',
  'rgba(255,240,200,',
  'rgba(255,200,180,',
  'rgba(180,200,255,',
  'rgba(255,255,255,',
];

function init() {
  W = canvas.width  = window.innerWidth;
  H = canvas.height = window.innerHeight;
  stars = [];
  shooters = [];
  bhx = W * 0.85;
  bhy = H * 0.15;
  psx = W * 0.12;
  psy = H * 0.80;

  // Layer 1 — distant, barely moving
  for (let i = 0; i < 200; i++) {
    const x = rand(0, W), y = rand(0, H);
    stars.push({ x, y, ox: x, oy: y, size: rand(0.4, 0.8),
      op: rand(0.15, 0.5), twinkle: rand(0, Math.PI*2),
      twSpeed: rand(0.004, 0.012), color: COLORS[Math.floor(rand(0,5))], layer: 1 });
  }
  // Layer 2 — mid
  for (let i = 0; i < 90; i++) {
    const x = rand(0, W), y = rand(0, H);
    stars.push({ x, y, ox: x, oy: y, size: rand(0.8, 1.4),
      op: rand(0.3, 0.7), twinkle: rand(0, Math.PI*2),
      twSpeed: rand(0.008, 0.018), color: COLORS[Math.floor(rand(0,5))], layer: 2 });
  }
  // Layer 3 — foreground, most parallax
  for (let i = 0; i < 30; i++) {
    const x = rand(0, W), y = rand(0, H);
    stars.push({ x, y, ox: x, oy: y, size: rand(1.5, 2.5),
      op: rand(0.5, 0.9), twinkle: rand(0, Math.PI*2),
      twSpeed: rand(0.012, 0.025), color: COLORS[Math.floor(rand(0,5))], layer: 3 });
  }
}

function drawStars() {
  const cx = W / 2, cy = H / 2;
  // Smooth mouse follow
  mouseX = lerp(mouseX, targetMouseX, 0.09);
  mouseY = lerp(mouseY, targetMouseY, 0.09);
  const dx = mouseX > 0 ? (mouseX - cx) / cx : 0;
  const dy = mouseX > 0 ? (mouseY - cy) / cy : 0;

  for (const s of stars) {
    const speed = s.layer * 0.028;
    const tx = s.ox + dx * speed * W * 9;
    const ty = s.oy + dy * speed * H * 9;

    // Black hole subtle pull — only when BH is in view
    const d = dist(s.ox, s.oy, bhx, bhy);
    let pullX = tx, pullY = ty;
    if (d < 280 && d > 25) {
      const pull = (280 - d) / 280 * 0.10;
      pullX = lerp(tx, bhx, pull);
      pullY = lerp(ty, bhy, pull);
    }

    // Grav wave distortion
    const dw = dist(s.ox, s.oy, gravWaveX, gravWaveY);
    if (gravWaveOp > 0 && Math.abs(dw - gravWaveR) < 18) {
      const angle = Math.atan2(s.oy - gravWaveY, s.ox - gravWaveX);
      const ripple = Math.sin((dw - gravWaveR) * 0.4) * 5 * gravWaveOp;
      pullX += Math.cos(angle) * ripple;
      pullY += Math.sin(angle) * ripple;
    }

    s.x = lerp(s.x, pullX, 0.04);
    s.y = lerp(s.y, pullY, 0.04);

    s.twinkle += s.twSpeed;
    const op = Math.max(0, Math.min(1, s.op * (0.65 + 0.35 * Math.sin(s.twinkle))));

    // Subtle glow for bigger stars
    if (s.size > 1.5) {
      const g = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.size * 4);
      g.addColorStop(0, s.color + op * 0.4 + ')');
      g.addColorStop(1, s.color + '0)');
      ctx.beginPath(); ctx.arc(s.x, s.y, s.size * 4, 0, Math.PI*2);
      ctx.fillStyle = g; ctx.fill();
    }

    ctx.beginPath(); ctx.arc(s.x, s.y, s.size, 0, Math.PI*2);
    ctx.fillStyle = s.color + op + ')'; ctx.fill();

    // Subtle cross on brightest
    if (s.size > 2 && op > 0.8) {
      ctx.strokeStyle = s.color + (op * 0.3) + ')';
      ctx.lineWidth = 0.5;
      ctx.beginPath();
      ctx.moveTo(s.x - s.size*2.5, s.y); ctx.lineTo(s.x + s.size*2.5, s.y);
      ctx.moveTo(s.x, s.y - s.size*2.5); ctx.lineTo(s.x, s.y + s.size*2.5);
      ctx.stroke();
    }
  }
}

function drawBlackHole() {
  // Very subtle — just a dark vignette with a faint accretion glow
  const g = ctx.createRadialGradient(bhx, bhy, 10, bhx, bhy, 80);
  g.addColorStop(0,   'rgba(0,0,0,0.85)');
  g.addColorStop(0.5, 'rgba(0,0,0,0.3)');
  g.addColorStop(1,   'rgba(0,0,0,0)');
  ctx.beginPath(); ctx.arc(bhx, bhy, 80, 0, Math.PI*2);
  ctx.fillStyle = g; ctx.fill();

  // Faint accretion ring
  ctx.save();
  ctx.translate(bhx, bhy);
  ctx.rotate(frame * 0.006);
  ctx.scale(1, 0.25);
  const ring = ctx.createRadialGradient(0,0,14,0,0,42);
  ring.addColorStop(0,   'rgba(200,120,40,0)');
  ring.addColorStop(0.4, 'rgba(200,120,40,0.28)');
  ring.addColorStop(0.7, 'rgba(180,100,30,0.14)');
  ring.addColorStop(1,   'rgba(0,0,0,0)');
  ctx.beginPath(); ctx.arc(0, 0, 42, 0, Math.PI*2);
  ctx.fillStyle = ring; ctx.fill();
  ctx.restore();

  // Event horizon
  ctx.beginPath(); ctx.arc(bhx, bhy, 12, 0, Math.PI*2);
  ctx.fillStyle = '#000'; ctx.fill();
}

function drawPulsar() {
  // Pulse every ~200 frames
  if (frame - lastPulse > 200) { lastPulse = frame; pulseFlash = 1; }
  pulseFlash = Math.max(0, pulseFlash - 0.02);

  // Rotating beams — very faint
  const angle = frame * 0.04;
  for (const off of [0, Math.PI]) {
    const ex = psx + Math.cos(angle + off) * 120;
    const ey = psy + Math.sin(angle + off) * 120;
    const beam = ctx.createLinearGradient(psx, psy, ex, ey);
    beam.addColorStop(0,   `rgba(180,220,255,${0.18 + pulseFlash * 0.35})`);
    beam.addColorStop(0.5, `rgba(150,200,255,${0.07 + pulseFlash * 0.15})`);
    beam.addColorStop(1,   'rgba(100,160,255,0)');
    ctx.beginPath(); ctx.moveTo(psx, psy); ctx.lineTo(ex, ey);
    ctx.strokeStyle = beam; ctx.lineWidth = 1.5 + pulseFlash * 2; ctx.stroke();
  }

  // Core dot
  ctx.beginPath(); ctx.arc(psx, psy, 3, 0, Math.PI*2);
  ctx.fillStyle = `rgba(200,230,255,${0.6 + pulseFlash * 0.4})`; ctx.fill();

  // Subtle background flash on pulse
  if (pulseFlash > 0.4) {
    ctx.fillStyle = `rgba(150,200,255,${pulseFlash * 0.025})`;
    ctx.fillRect(0, 0, W, H);
  }
}

function drawShooters() {
  for (const s of shooters) {
    if (!s.active) continue;
    s.trail.push({ x: s.x, y: s.y });
    if (s.trail.length > 16) s.trail.shift();
    s.x += s.vx; s.y += s.vy; s.op -= 0.022;
    if (s.op <= 0 || s.x > W + 50) { s.active = false; continue; }
    for (let i = 0; i < s.trail.length; i++) {
      const t = s.trail[i], frac = i / s.trail.length;
      ctx.beginPath(); ctx.arc(t.x, t.y, 0.8 * frac, 0, Math.PI*2);
      ctx.fillStyle = `rgba(255,255,240,${s.op * frac * 0.45})`; ctx.fill();
    }
    // Head
    ctx.beginPath(); ctx.arc(s.x, s.y, 2, 0, Math.PI*2);
    ctx.fillStyle = `rgba(255,255,255,${s.op})`; ctx.fill();
  }
  shooters = shooters.filter(s => s.active);
}

function updateGravWave() {
  if (frame - lastGravWave > rand(1400, 2200) && Math.random() < 0.004) {
    lastGravWave = frame;
    gravWaveX = rand(W*0.2, W*0.8);
    gravWaveY = rand(H*0.2, H*0.8);
    gravWaveR = 0;
    gravWaveOp = 0.5;
  }
  if (gravWaveOp > 0) {
    gravWaveR += 3.5;
    gravWaveOp -= 0.003;
    ctx.beginPath(); ctx.arc(gravWaveX, gravWaveY, gravWaveR, 0, Math.PI*2);
    ctx.strokeStyle = `rgba(180,220,255,${gravWaveOp * 0.18})`; ctx.lineWidth = 1.5; ctx.stroke();
  }
}

// Subtle gold cursor trail
const cursorTrail: {x:number;y:number;op:number}[] = [];
function drawCursorTrail() {
  if (targetMouseX < 0) return;
  cursorTrail.push({ x: targetMouseX + rand(-3,3), y: targetMouseY + rand(-3,3), op: 0.8 });
  if (cursorTrail.length > 32) cursorTrail.shift();
  for (let i = 0; i < cursorTrail.length; i++) {
    const t = cursorTrail[i], frac = i / cursorTrail.length;
    t.op -= 0.028;
    if (t.op <= 0) continue;
    ctx.beginPath(); ctx.arc(t.x, t.y, 0.9 * frac, 0, Math.PI*2);
    ctx.fillStyle = `rgba(200,169,110,${t.op * frac})`; ctx.fill();
  }
}

function draw() {
  if (!active) return;
  frame++;
  ctx.clearRect(0, 0, W, H);

  drawStars();
  drawBlackHole();
  drawPulsar();
  drawShooters();
  updateGravWave();
  drawCursorTrail();

  if (frame - lastShooter > rand(70, 130)) {
    shooters.push({ x: rand(0, W*0.6), y: rand(0, H*0.4),
      vx: rand(5,10), vy: rand(1.5,4), op: 1, trail: [], active: true });
    lastShooter = frame;
  }

  animFrame = requestAnimationFrame(draw);
}

function deactivate() {
  active = false;
  btn.classList.remove('active');
  canvas.classList.remove('active');
  cancelAnimationFrame(animFrame);
  ctx.clearRect(0, 0, W, H);
}

btn.addEventListener('click', () => {
  active = !active;
  btn.classList.toggle('active', active);
  canvas.classList.toggle('active', active);
  if (active) { init(); animFrame = requestAnimationFrame(draw); }
  else { cancelAnimationFrame(animFrame); ctx.clearRect(0, 0, W, H); }
});

// Auto-off on navigation
document.addEventListener('astro:before-preparation', deactivate);
document.addEventListener('astro:page-load', deactivate);
window.addEventListener('beforeunload', deactivate);
// Fallback for non-Astro navigation
document.querySelectorAll('a').forEach(a => {
  a.addEventListener('click', () => {
    if (!a.href.includes(window.location.pathname)) deactivate();
  });
});

window.addEventListener('mousemove', e => { targetMouseX = e.clientX; targetMouseY = e.clientY; });
window.addEventListener('resize', () => { if (active) init(); });
</script>