---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'] & { body?: string };

const { title, description, pubDate, updatedDate, heroImage, tags, body } = Astro.props;

const readingTime = body
  ? Math.max(1, Math.ceil(body.trim().split(/\s+/).length / 200))
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description ?? ''} image={heroImage} />
  </head>
  <body>
    <Header />
    <main>
      <div class="site-wrapper">
        <a href="/blog" class="back-link">All Posts</a>

        <header class="post-header">
          <div class="post-meta">
            <span class="post-meta-date"><FormattedDate date={pubDate} /></span>
            {readingTime && (
              <span style="font-family:var(--font-mono);font-size:0.65rem;color:var(--accent-cyan);letter-spacing:0.05em;">
                {readingTime} min read
              </span>
            )}
            {updatedDate && (
              <span class="post-meta-date" style="opacity:0.6;">
                Updated: <FormattedDate date={updatedDate} />
              </span>
            )}
          </div>
          <h1 class="post-title">{title}</h1>
          {description && <p class="post-description">{description}</p>}
          {tags && tags.length > 0 && (
            <div class="post-tags" style="margin-top:1rem;">
              {tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </header>

        {heroImage && <img class="post-hero-image" src={heroImage} alt={title} />}

        <div class="prose">
          <slot />
        </div>

        <hr style="margin:4rem 0;" />
        <a href="/blog" class="back-link">Back to all posts</a>
      </div>
    </main>
    <Footer />
  </body>
</html>